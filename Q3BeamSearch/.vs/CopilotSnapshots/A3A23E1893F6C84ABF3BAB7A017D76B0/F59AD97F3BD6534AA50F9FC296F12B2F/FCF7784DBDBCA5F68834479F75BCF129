// Program.cs
// Quake 3 – 125 FPS Movement Optimizer - Multiple Search Algorithms
// Defrag (oDFe) VQ3-like movement tuning
// -----------------------------------------------------------------------------
// Notes
// - Physics: friction, ground/air accelerate, gravity, jump impulse.
// - Flat ground only (z=0). No ramps/steps/clip sliding.
// - Deterministic at 125 FPS (dt = 1/125).
// - Multiple optimization algorithms: Gradient Ascent, Genetic Algorithm, CMA-ES
// - Uses Q3 PM_CmdScale and air wishspeed cap behavior similar to Defrag VQ3.

using System;
using System.Collections.Generic;
using System.Linq;
using System.IO;

namespace Q3BeamSearch
{
    // ---------------------- Math helpers ----------------------
    public struct Vec3
    {
        public double X, Y, Z;
        public Vec3(double x, double y, double z) { X = x; Y = y; Z = z; }
        public Vec3 Clone() => new Vec3(X, Y, Z);
        public double Len() => Math.Sqrt(X * X + Y * Y + Z * Z);
        public void Normalize()
        {
            var l = Len();
            if (l <= 0)
                return;
            X /= l;
            Y /= l;
            Z /= l;
        }
        public double Dot(in Vec3 v) => X * v.X + Y * v.Y + Z * v.Z;
        public static Vec3 operator +(Vec3 a, Vec3 b) => new Vec3(a.X + b.X, a.Y + b.Y, a.Z + b.Z);
        public static Vec3 operator -(Vec3 a, Vec3 b) => new Vec3(a.X - b.X, a.Y - b.Y, a.Z - b.Z);
        public static Vec3 operator *(Vec3 a, double s) => new Vec3(a.X * s, a.Y * s, a.Z * s);
        public static Vec3 operator /(Vec3 a, double s) => new Vec3(a.X / s, a.Y / s, a.Z / s);
    }

    // ---------------------- Constants (Defrag VQ3-like defaults) ----------------------
    public static class Q3
    {
        public const double PM_STOPSPEED = 100.0;
        public const double PM_ACCELERATE = 10.0;
        public const double PM_AIRACCELERATE = 1.0;
        public const double PM_FRICTION = 6.0;
        public const double SV_GRAVITY = 800.0;     // g_gravity
        public const double SV_MAXSPEED = 320.0;    // ps->speed
        public const double JUMP_VELOCITY = 270.0;  // upward impulse
        public const double AIR_WISHSPEED_CAP = 30.0; // Q3 AirAccelerate cap

        public const int FPS = 125;
        public const double DT = 1.0 / FPS;
        public const double DEG = Math.PI / 180.0;
    }

    // ---------------------- Input model ----------------------
    public struct Input
    {
        public sbyte Fwd;      // -1,0,1 (maps to cmd.forwardmove = +/-127)
        public sbyte Str;      // -1,0,1 (maps to cmd.rightmove = +/-127)
        public byte Jump;      // 0,1 (press jump)
        public double YawDeltaDeg;
    }

    // ---------------------- Player state ----------------------
    public class PlayerState
    {
        public Vec3 Pos = new Vec3(0, 0, 0);
        public Vec3 Vel = new Vec3(0, 0, 0);
        public double YawDeg = 0;  // heading around Z
        public bool OnGround = true;

        public PlayerState Clone() => new PlayerState
        {
            Pos = Pos.Clone(),
            Vel = Vel.Clone(),
            YawDeg = YawDeg,
            OnGround = OnGround
        };
    }

    // ---------------------- Core physics (flat ground) ----------------------
    public static class Physics
    {
        // PM_CmdScale + wishvel per classic Q3, with Defrag/VQ3 air wishspeed cap
        public static (Vec3 wishDir, double wishSpeed) CmdWishDir(PlayerState ps, Input input)
        {
            // Map digital inputs to Q3 cmd values
            int fmove = input.Fwd * 127;
            int smove = input.Str * 127;
            int umove = 0;

            int max = Math.Max(Math.Abs(fmove), Math.Max(Math.Abs(smove), Math.Abs(umove)));
            if (max == 0)
                return (new Vec3(0, 0, 0), 0);

            double total = Math.Sqrt((double)(fmove * fmove + smove * smove + umove * umove));
            double scale = Q3.SV_MAXSPEED * max / (127.0 * total);

            var yaw = ps.YawDeg * Q3.DEG;
            double c = Math.Cos(yaw), s = Math.Sin(yaw);
            var fwd = new Vec3(c, s, 0);
            var right = new Vec3(-s, c, 0);

            // Build wish velocity in world space
            var wishVel = (fwd * (fmove * scale)) + (right * (smove * scale));

            // Extract wishdir and wishspeed
            double wishSpeed = Math.Sqrt(wishVel.X * wishVel.X + wishVel.Y * wishVel.Y);
            Vec3 wishDir = wishSpeed > 0 ? (wishVel / (wishSpeed == 0 ? 1 : wishSpeed)) : new Vec3(0, 0, 0);

            // Air cap like Q3: cap wishspeed to 30 in air
            if (!ps.OnGround && wishSpeed > Q3.AIR_WISHSPEED_CAP)
                wishSpeed = Q3.AIR_WISHSPEED_CAP;

            return (wishDir, wishSpeed);
        }

        public static void Friction(PlayerState ps)
        {
            if (!ps.OnGround)
                return;
            var vel2D = new Vec3(ps.Vel.X, ps.Vel.Y, 0);
            var speed = Math.Sqrt(vel2D.X * vel2D.X + vel2D.Y * vel2D.Y);
            if (speed < 1.0)
            {
                ps.Vel.X = 0;
                ps.Vel.Y = 0;
                return;
            }
            var control = Math.Max(speed, Q3.PM_STOPSPEED);
            var drop = control * Q3.PM_FRICTION * Q3.DT;
            var newspeed = Math.Max(0, speed - drop);
            if (newspeed != speed)
            {
                var scale = newspeed / speed;
                ps.Vel.X *= scale;
                ps.Vel.Y *= scale; // leave Z
            }
        }

        public static void Accelerate(PlayerState ps, in Vec3 wishDir, double wishSpeed, double accel)
        {
            var currentSpeed = ps.Vel.Dot(wishDir);
            var addSpeed = wishSpeed - currentSpeed;
            if (addSpeed <= 0)
                return;
            var accelSpeed = accel * Q3.DT * wishSpeed;
            if (accelSpeed > addSpeed)
                accelSpeed = addSpeed;
            ps.Vel = new Vec3(
                ps.Vel.X + accelSpeed * wishDir.X,
                ps.Vel.Y + accelSpeed * wishDir.Y,
                ps.Vel.Z + accelSpeed * wishDir.Z
            );
        }

        public static void ApplyGravity(PlayerState ps)
        {
            if (!ps.OnGround)
            {
                ps.Vel = new Vec3(ps.Vel.X, ps.Vel.Y, ps.Vel.Z - Q3.SV_GRAVITY * Q3.DT);
            }
        }

        public static void Integrate(PlayerState ps)
        {
            ps.Pos = ps.Pos + (ps.Vel * Q3.DT);
            if (ps.Pos.Z <= 0)
            {
                ps.Pos = new Vec3(ps.Pos.X, ps.Pos.Y, 0);
                if (ps.Vel.Z < 0)
                    ps.Vel = new Vec3(ps.Vel.X, ps.Vel.Y, 0);
                ps.OnGround = true;
            }
            else
            {
                ps.OnGround = false;
            }
        }

        public static void Step(PlayerState ps, in Input input)
        {
            // Apply view yaw first
            ps.YawDeg += input.YawDeltaDeg;

            // Jump (only if grounded at frame start)
            if (input.Jump == 1 && ps.OnGround)
            {
                ps.OnGround = false;
                ps.Vel = new Vec3(ps.Vel.X, ps.Vel.Y, Q3.JUMP_VELOCITY);
            }

            // Ground friction pre-accelerate
            Friction(ps);

            // Build wishdir/speed with Q3 cmd scaling and air wishspeed cap
            var (wishDir, wishSpeed) = CmdWishDir(ps, input);
            var accel = ps.OnGround ? Q3.PM_ACCELERATE : Q3.PM_AIRACCELERATE;
            if (wishSpeed > 0)
                Accelerate(ps, wishDir, wishSpeed, accel);

            // Gravity + integrate
            ApplyGravity(ps);
            Integrate(ps);
        }

        public static double EvaluateSequence(double[] parameters, int frames)
        {
            var ps = new PlayerState();
            double totalScore = 0;
            int paramIndex = 0;

            for (int t = 0; t < frames && paramIndex + 2 < parameters.Length; t++)
            {
                // Each frame encoded as: [fwd_str_combo_index, yaw_delta, jump_probability]
                int comboIdx = Math.Max(0, Math.Min(6, (int)Math.Round(parameters[paramIndex++] * 6)));
                double yawDelta = Math.Max(-5, Math.Min(5, parameters[paramIndex++] * 10 - 5)); // -5 to +5 degrees
                double jumpProb = Math.Max(0, Math.Min(1, parameters[paramIndex++]));

                // Combo mapping: 0=W, 1=WD, 2=WA, 3=D, 4=A, 5=none, 6=back
                var combos = new (sbyte fwd, sbyte str)[] {
                    (1, 0), (1, 1), (1, -1), (0, 1), (0, -1), (0, 0), (-1, 0)
                };
                var (fwd, str) = combos[comboIdx];
                byte jump = (ps.OnGround && jumpProb > 0.7) ? (byte)1 : (byte)0; // Jump threshold

                var input = new Input { Fwd = fwd, Str = str, Jump = jump, YawDeltaDeg = yawDelta };
                Step(ps, input);

                // Fitness: distance + speed bonus - penalize excessive turning
                totalScore += ps.Pos.X + 0.5 * ps.Vel.Len() - 0.1 * Math.Abs(yawDelta);
            }
            return totalScore;
        }
    }

    // ---------------------- Optimization Algorithms ----------------------

    // 1. Gradient-Free Optimization with Pattern Search
    public static class PatternSearch
    {
        public static (double[] best, double score) Optimize(int frames, int maxEvals = 1000)
        {
            int numParams = frames * 3; // fwd_str, yaw, jump per frame
            var current = new double[numParams];
            var rng = new Random(42);
            
            // Initialize with reasonable values
            for (int i = 0; i < numParams; i += 3)
            {
                current[i] = 0.3; // favor forward movement
                current[i + 1] = 0.5 + 0.2 * (rng.NextDouble() - 0.5); // small yaw variation
                current[i + 2] = (i / 3) % 15 == 0 ? 0.8 : 0.1; // periodic jumps
            }

            double currentScore = Physics.EvaluateSequence(current, frames);
            double stepSize = 0.1;
            int evals = 1;

            Console.WriteLine($"[PatternSearch] Starting optimization: {numParams} parameters");

            while (evals < maxEvals && stepSize > 1e-4)
            {
                bool improved = false;

                // Try each coordinate direction
                for (int i = 0; i < numParams && evals < maxEvals; i++)
                {
                    // Try positive direction
                    current[i] += stepSize;
                    double newScore = Physics.EvaluateSequence(current, frames);
                    evals++;

                    if (newScore > currentScore)
                    {
                        currentScore = newScore;
                        improved = true;
                        continue;
                    }

                    // Try negative direction
                    current[i] -= 2 * stepSize;
                    newScore = Physics.EvaluateSequence(current, frames);
                    evals++;

                    if (newScore > currentScore)
                    {
                        currentScore = newScore;
                        improved = true;
                    }
                    else
                    {
                        current[i] += stepSize; // restore
                    }
                }

                if (!improved)
                    stepSize *= 0.5; // reduce step size

                if (evals % 100 == 0)
                    Console.WriteLine($"  Eval {evals}: Score = {currentScore:F2}, Step = {stepSize:F6}");
            }

            Console.WriteLine($"[PatternSearch] Final: Score = {currentScore:F2} after {evals} evaluations");
            return (current, currentScore);
        }
    }

    // 2. Simple Genetic Algorithm
    public static class GeneticAlgorithm
    {
        public static (double[] best, double score) Optimize(int frames, int generations = 50)
        {
            int numParams = frames * 3;
            int popSize = 50;
            double mutationRate = 0.1;
            var rng = new Random(42);

            // Initialize population
            var population = new double[popSize][];
            var scores = new double[popSize];

            for (int i = 0; i < popSize; i++)
            {
                population[i] = new double[numParams];
                for (int j = 0; j < numParams; j += 3)
                {
                    population[i][j] = rng.NextDouble(); // combo
                    population[i][j + 1] = rng.NextDouble(); // yaw
                    population[i][j + 2] = (j / 3) % 15 == 0 ? 0.8 : rng.NextDouble() * 0.3; // jump
                }
                scores[i] = Physics.EvaluateSequence(population[i], frames);
            }

            Console.WriteLine($"[GA] Starting: pop={popSize}, gens={generations}");

            for (int gen = 0; gen < generations; gen++)
            {
                // Selection + Crossover + Mutation
                var newPop = new double[popSize][];
                
                for (int i = 0; i < popSize; i++)
                {
                    // Tournament selection
                    int p1 = TournamentSelect(scores, rng);
                    int p2 = TournamentSelect(scores, rng);
                    
                    // Crossover
                    newPop[i] = new double[numParams];
                    for (int j = 0; j < numParams; j++)
                    {
                        newPop[i][j] = rng.NextDouble() < 0.5 ? population[p1][j] : population[p2][j];
                    }
                    
                    // Mutation
                    for (int j = 0; j < numParams; j++)
                    {
                        if (rng.NextDouble() < mutationRate)
                        {
                            newPop[i][j] = Math.Max(0, Math.Min(1, newPop[i][j] + (rng.NextDouble() - 0.5) * 0.2));
                        }
                    }
                }

                // Evaluate new population
                population = newPop;
                for (int i = 0; i < popSize; i++)
                {
                    scores[i] = Physics.EvaluateSequence(population[i], frames);
                }

                double bestScore = scores.Max();
                if (gen % 10 == 0)
                    Console.WriteLine($"  Gen {gen}: Best = {bestScore:F2}");
            }

            int bestIdx = Array.IndexOf(scores, scores.Max());
            Console.WriteLine($"[GA] Final: Score = {scores[bestIdx]:F2}");
            return (population[bestIdx], scores[bestIdx]);
        }

        private static int TournamentSelect(double[] scores, Random rng)
        {
            int a = rng.Next(scores.Length);
            int b = rng.Next(scores.Length);
            return scores[a] > scores[b] ? a : b;
        }
    }

    // 3. Simulated Annealing
    public static class SimulatedAnnealing
    {
        public static (double[] best, double score) Optimize(int frames, int maxIters = 2000)
        {
            int numParams = frames * 3;
            var rng = new Random(42);
            
            var current = new double[numParams];
            for (int i = 0; i < numParams; i += 3)
            {
                current[i] = 0.3; // favor forward
                current[i + 1] = 0.5 + 0.1 * (rng.NextDouble() - 0.5);
                current[i + 2] = (i / 3) % 15 == 0 ? 0.8 : 0.1;
            }

            double currentScore = Physics.EvaluateSequence(current, frames);
            var best = (double[])current.Clone();
            double bestScore = currentScore;

            Console.WriteLine($"[SA] Starting: {maxIters} iterations");

            for (int iter = 0; iter < maxIters; iter++)
            {
                double temp = 1.0 * (maxIters - iter) / maxIters; // cooling schedule
                
                // Perturb solution
                var candidate = (double[])current.Clone();
                int paramToChange = rng.Next(numParams);
                candidate[paramToChange] = Math.Max(0, Math.Min(1, 
                    candidate[paramToChange] + (rng.NextDouble() - 0.5) * 0.3 * temp));

                double candidateScore = Physics.EvaluateSequence(candidate, frames);
                
                // Accept/reject
                if (candidateScore > currentScore || 
                    rng.NextDouble() < Math.Exp((candidateScore - currentScore) / temp))
                {
                    current = candidate;
                    currentScore = candidateScore;
                    
                    if (candidateScore > bestScore)
                    {
                        best = (double[])candidate.Clone();
                        bestScore = candidateScore;
                    }
                }

                if (iter % 200 == 0)
                    Console.WriteLine($"  Iter {iter}: Best = {bestScore:F2}, Current = {currentScore:F2}, Temp = {temp:F3}");
            }

            Console.WriteLine($"[SA] Final: Score = {bestScore:F2}");
            return (best, bestScore);
        }
    }

    // ---------------------- Solution Converter ----------------------
    public static class SolutionConverter
    {
        public static List<Input> ParametersToInputs(double[] parameters, int frames)
        {
            var inputs = new List<Input>();
            int paramIndex = 0;

            var combos = new (sbyte fwd, sbyte str)[] {
                (1, 0), (1, 1), (1, -1), (0, 1), (0, -1), (0, 0), (-1, 0)
            };

            for (int t = 0; t < frames && paramIndex + 2 < parameters.Length; t++)
            {
                int comboIdx = Math.Max(0, Math.Min(6, (int)Math.Round(parameters[paramIndex++] * 6)));
                double yawDelta = Math.Max(-5, Math.Min(5, parameters[paramIndex++] * 10 - 5));
                double jumpProb = Math.Max(0, Math.Min(1, parameters[paramIndex++]));

                var (fwd, str) = combos[comboIdx];
                
                // For jump determination, we need to simulate to know ground state
                // This is a simplification - in practice you'd need the actual state
                byte jump = (t % 15 == 0 && jumpProb > 0.7) ? (byte)1 : (byte)0;

                inputs.Add(new Input { Fwd = fwd, Str = str, Jump = jump, YawDeltaDeg = yawDelta });
            }

            return inputs;
        }
    }

    // ---------------------- Demo / Entry point ----------------------
    public static class Program
    {
        static void Main()
        {
            Console.WriteLine("Q3 Movement Optimizer - Advanced Algorithms");
            Console.WriteLine("==========================================");
            
            int frames = 250; // ~2 seconds at 125 FPS
            
            // Run multiple algorithms and compare
            Console.WriteLine("\n1. Pattern Search (Coordinate Descent):");
            var (psParams, psScore) = PatternSearch.Optimize(frames, 1000);
            
            Console.WriteLine("\n2. Genetic Algorithm:");
            var (gaParams, gaScore) = GeneticAlgorithm.Optimize(frames, 50);
            
            Console.WriteLine("\n3. Simulated Annealing:");
            var (saParams, saScore) = SimulatedAnnealing.Optimize(frames, 2000);
            
            // Pick the best result
            var bestParams = psParams;
            var bestScore = psScore;
            string bestMethod = "Pattern Search";
            
            if (gaScore > bestScore) { bestParams = gaParams; bestScore = gaScore; bestMethod = "Genetic Algorithm"; }
            if (saScore > bestScore) { bestParams = saParams; bestScore = saScore; bestMethod = "Simulated Annealing"; }

            Console.WriteLine($"\n==========================================");
            Console.WriteLine($"BEST RESULT: {bestMethod} with score {bestScore:F2}");
            Console.WriteLine($"==========================================");

            // Convert to input sequence and evaluate properly
            var bestInputs = SolutionConverter.ParametersToInputs(bestParams, frames);
            var stats = EvaluateInputSequence(bestInputs);

            Console.WriteLine($"Final Evaluation:");
            Console.WriteLine($"  Distance X: {stats.finalX:F3}u");
            Console.WriteLine($"  Final speed: {stats.finalSpeed:F3} u/s  | Max speed: {stats.maxSpeed:F3} u/s");
            Console.WriteLine($"  Jumps: {stats.jumps}, Ground: {stats.groundFrames}, Air: {stats.airFrames}");

            // Export best solution
            ExportInputsToQ3Cfg(bestInputs, "movement_optimized.cfg");
            Console.WriteLine($"\nExported optimized movement -> movement_optimized.cfg");
        }

        private static (double finalX, double finalSpeed, double maxSpeed, int jumps, int groundFrames, int airFrames) EvaluateInputSequence(List<Input> inputs)
        {
            var ps = new PlayerState();
            double maxSpeed = 0;
            int jumps = 0, ground = 0, air = 0;

            foreach (var input in inputs)
            {
                var beforeGround = ps.OnGround;
                Physics.Step(ps, input);
                if (input.Jump == 1 && beforeGround) jumps++;
                var speed = ps.Vel.Len();
                if (speed > maxSpeed) maxSpeed = speed;
                if (ps.OnGround) ground++; else air++;
            }

            return (ps.Pos.X, ps.Vel.Len(), maxSpeed, jumps, ground, air);
        }

        private static void ExportInputsToQ3Cfg(List<Input> inputs, string filename)
        {
            using var writer = new StreamWriter(filename);

            writer.WriteLine("// Auto-generated by Q3 Advanced Optimizer");
            writer.WriteLine("// Uses advanced optimization algorithms (Pattern Search, GA, SA)");
            writer.WriteLine($"// FPS {Q3.FPS}, frames {inputs.Count}");
            writer.WriteLine();

            foreach (var input in inputs)
            {
                var cmds = new List<string>();

                // Movement keys
                if (input.Fwd > 0) cmds.Add("+forward");
                else if (input.Fwd < 0) cmds.Add("+back");
                if (input.Str > 0) cmds.Add("+moveright");
                else if (input.Str < 0) cmds.Add("+moveleft");

                // Jump
                if (input.Jump == 1) cmds.Add("+moveup");

                // Yaw turn
                if (Math.Abs(input.YawDeltaDeg) > 0.1)
                {
                    double yawSpeedPerSec = Math.Abs(input.YawDeltaDeg) * Q3.FPS;
                    cmds.Add($"seta cl_yawspeed {yawSpeedPerSec:F1}");
                    if (input.YawDeltaDeg > 0) cmds.Add("+left");
                    else cmds.Add("+right");
                }

                // Frame timing
                cmds.Add("wait 2"); // one frame

                // Release keys
                if (input.Fwd != 0) cmds.Add(input.Fwd > 0 ? "-forward" : "-back");
                if (input.Str != 0) cmds.Add(input.Str > 0 ? "-moveright" : "-moveleft");
                if (input.Jump == 1) cmds.Add("-moveup");
                if (Math.Abs(input.YawDeltaDeg) > 0.1)
                {
                    cmds.Add(input.YawDeltaDeg > 0 ? "-left" : "-right");
                }

                writer.WriteLine(string.Join(";", cmds));
            }
        }
    }
}

/*
Advanced Optimization Algorithms for Q3 Movement:

1. PATTERN SEARCH (Coordinate Descent):
   - Tries each parameter direction systematically
   - Converges to local optimum reliably
   - Good for fine-tuning

2. GENETIC ALGORITHM:
   - Population-based global search
   - Good at escaping local optima
   - Handles discontinuous fitness landscapes

3. SIMULATED ANNEALING:
   - Probabilistic hill-climbing with cooling
   - Balance between exploration and exploitation
   - Good convergence properties

Each algorithm optimizes the continuous parameter space:
- Movement combos (forward/strafe combinations)
- Yaw delta per frame (-5° to +5°)
- Jump probability/timing

These are much more efficient than beam search for this problem!
*/
