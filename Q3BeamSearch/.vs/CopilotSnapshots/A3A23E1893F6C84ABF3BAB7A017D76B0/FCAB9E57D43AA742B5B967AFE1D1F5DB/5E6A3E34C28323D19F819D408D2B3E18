// Program.cs
// Quake 3 – 125 FPS Movement (flat ground) + Beam-Search Optimizer
// Defrag (oDFe) VQ3-like movement tuning
// -----------------------------------------------------------------------------
// Notes
// - Physics: friction, ground/air accelerate, gravity, jump impulse.
// - Flat ground only (z=0). No ramps/steps/clip sliding.
// - Deterministic at 125 FPS (dt = 1/125).
// - Beam-search explores key combos + small yaw turns to maximize X distance.
// - Uses Q3 PM_CmdScale and air wishspeed cap behavior similar to Defrag VQ3.

using System;
using System.Collections.Generic;
using System.Linq;
using System.IO;

namespace Q3BeamSearch
{
    // ---------------------- Math helpers ----------------------
    public struct Vec3
    {
        public double X, Y, Z;
        public Vec3(double x, double y, double z) { X = x; Y = y; Z = z; }
        public Vec3 Clone() => new Vec3(X, Y, Z);
        public double Len() => Math.Sqrt(X * X + Y * Y + Z * Z);
        public void Normalize()
        {
            var l = Len();
            if (l <= 0)
                return;
            X /= l;
            Y /= l;
            Z /= l;
        }
        public double Dot(in Vec3 v) => X * v.X + Y * v.Y + Z * v.Z;
        public static Vec3 operator +(Vec3 a, Vec3 b) => new Vec3(a.X + b.X, a.Y + b.Y, a.Z + b.Z);
        public static Vec3 operator -(Vec3 a, Vec3 b) => new Vec3(a.X - b.X, a.Y - b.Y, a.Z - b.Z);
        public static Vec3 operator *(Vec3 a, double s) => new Vec3(a.X * s, a.Y * s, a.Z * s);
        public static Vec3 operator /(Vec3 a, double s) => new Vec3(a.X / s, a.Y / s, a.Z / s);
    }

    // ---------------------- Constants (Defrag VQ3-like defaults) ----------------------
    public static class Q3
    {
        public const double PM_STOPSPEED = 100.0;
        public const double PM_ACCELERATE = 10.0;
        public const double PM_AIRACCELERATE = 1.0;
        public const double PM_FRICTION = 6.0;
        public const double SV_GRAVITY = 800.0;     // g_gravity
        public const double SV_MAXSPEED = 320.0;    // ps->speed
        public const double JUMP_VELOCITY = 270.0;  // upward impulse
        public const double AIR_WISHSPEED_CAP = 30.0; // Q3 AirAccelerate cap

        public const int FPS = 125;
        public const double DT = 1.0 / FPS;
        public const double DEG = Math.PI / 180.0;
    }

    // ---------------------- Input model ----------------------
    public struct Input
    {
        public sbyte Fwd;      // -1,0,1 (maps to cmd.forwardmove = +/-127)
        public sbyte Str;      // -1,0,1 (maps to cmd.rightmove = +/-127)
        public byte Jump;      // 0,1 (press jump)
        public double YawDeltaDeg;
    }

    // ---------------------- Player state ----------------------
    public class PlayerState
    {
        public Vec3 Pos = new Vec3(0, 0, 0);
        public Vec3 Vel = new Vec3(0, 0, 0);
        public double YawDeg = 0;  // heading around Z
        public bool OnGround = true;

        public PlayerState Clone() => new PlayerState
        {
            Pos = Pos.Clone(),
            Vel = Vel.Clone(),
            YawDeg = YawDeg,
            OnGround = OnGround
        };
    }

    // ---------------------- Core physics (flat ground) ----------------------
    public static class Physics
    {
        // PM_CmdScale + wishvel per classic Q3, with Defrag/VQ3 air wishspeed cap
        public static (Vec3 wishDir, double wishSpeed) CmdWishDir(PlayerState ps, Input input)
        {
            // Map digital inputs to Q3 cmd values
            int fmove = input.Fwd * 127;
            int smove = input.Str * 127;
            int umove = 0;

            int max = Math.Max(Math.Abs(fmove), Math.Max(Math.Abs(smove), Math.Abs(umove)));
            if (max == 0)
                return (new Vec3(0, 0, 0), 0);

            double total = Math.Sqrt((double)(fmove * fmove + smove * smove + umove * umove));
            double scale = Q3.SV_MAXSPEED * max / (127.0 * total);

            var yaw = ps.YawDeg * Q3.DEG;
            double c = Math.Cos(yaw), s = Math.Sin(yaw);
            var fwd = new Vec3(c, s, 0);
            var right = new Vec3(-s, c, 0);

            // Build wish velocity in world space
            var wishVel = (fwd * (fmove * scale)) + (right * (smove * scale));

            // Extract wishdir and wishspeed
            double wishSpeed = Math.Sqrt(wishVel.X * wishVel.X + wishVel.Y * wishVel.Y);
            Vec3 wishDir = wishSpeed > 0 ? (wishVel / (wishSpeed == 0 ? 1 : wishSpeed)) : new Vec3(0, 0, 0);

            // Air cap like Q3: cap wishspeed to 30 in air
            if (!ps.OnGround && wishSpeed > Q3.AIR_WISHSPEED_CAP)
                wishSpeed = Q3.AIR_WISHSPEED_CAP;

            return (wishDir, wishSpeed);
        }

        public static void Friction(PlayerState ps)
        {
            if (!ps.OnGround)
                return;
            var vel2D = new Vec3(ps.Vel.X, ps.Vel.Y, 0);
            var speed = Math.Sqrt(vel2D.X * vel2D.X + vel2D.Y * vel2D.Y);
            if (speed < 1.0)
            {
                ps.Vel.X = 0;
                ps.Vel.Y = 0;
                return;
            }
            var control = Math.Max(speed, Q3.PM_STOPSPEED);
            var drop = control * Q3.PM_FRICTION * Q3.DT;
            var newspeed = Math.Max(0, speed - drop);
            if (newspeed != speed)
            {
                var scale = newspeed / speed;
                ps.Vel.X *= scale;
                ps.Vel.Y *= scale; // leave Z
            }
        }

        public static void Accelerate(PlayerState ps, in Vec3 wishDir, double wishSpeed, double accel)
        {
            var currentSpeed = ps.Vel.Dot(wishDir);
            var addSpeed = wishSpeed - currentSpeed;
            if (addSpeed <= 0)
                return;
            var accelSpeed = accel * Q3.DT * wishSpeed;
            if (accelSpeed > addSpeed)
                accelSpeed = addSpeed;
            ps.Vel = new Vec3(
                ps.Vel.X + accelSpeed * wishDir.X,
                ps.Vel.Y + accelSpeed * wishDir.Y,
                ps.Vel.Z + accelSpeed * wishDir.Z
            );
        }

        public static void ApplyGravity(PlayerState ps)
        {
            if (!ps.OnGround)
            {
                ps.Vel = new Vec3(ps.Vel.X, ps.Vel.Y, ps.Vel.Z - Q3.SV_GRAVITY * Q3.DT);
            }
        }

        public static void Integrate(PlayerState ps)
        {
            ps.Pos = ps.Pos + (ps.Vel * Q3.DT);
            if (ps.Pos.Z <= 0)
            {
                ps.Pos = new Vec3(ps.Pos.X, ps.Pos.Y, 0);
                if (ps.Vel.Z < 0)
                    ps.Vel = new Vec3(ps.Vel.X, ps.Vel.Y, 0);
                ps.OnGround = true;
            }
            else
            {
                ps.OnGround = false;
            }
        }

        public static void Step(PlayerState ps, in Input input)
        {
            // Apply view yaw first
            ps.YawDeg += input.YawDeltaDeg;

            // Jump (only if grounded at frame start)
            if (input.Jump == 1 && ps.OnGround)
            {
                ps.OnGround = false;
                ps.Vel = new Vec3(ps.Vel.X, ps.Vel.Y, Q3.JUMP_VELOCITY);
            }

            // Ground friction pre-accelerate
            Friction(ps);

            // Build wishdir/speed with Q3 cmd scaling and air wishspeed cap
            var (wishDir, wishSpeed) = CmdWishDir(ps, input);
            var accel = ps.OnGround ? Q3.PM_ACCELERATE : Q3.PM_AIRACCELERATE;
            if (wishSpeed > 0)
                Accelerate(ps, wishDir, wishSpeed, accel);

            // Gravity + integrate
            ApplyGravity(ps);
            Integrate(ps);
        }
    }

    // ---------------------- Beam search ----------------------
    public struct PlanInput
    {
        public sbyte Fwd, Str; public byte Jump; public double YawDeltaDeg;
        public override string ToString() => $"fwd={Fwd} str={Str} jump={Jump} yawΔ={YawDeltaDeg}";
    }

    public class Node
    {
        public PlayerState PS = new PlayerState();
        public List<PlanInput> Plan = new List<PlanInput>();
        public double Score; // use X distance
    }

    public static class Search
    {
        public class Options
        {
            public int Frames = 250;
            public int BeamWidth = 128;
            public double YawStepDeg = 0.5; // per-frame turn variations
            public List<(sbyte fwd, sbyte str, byte jump)> Combos = new()
            {
                (1, 0, 0),  // W
                (1, 1, 0),  // W + D
                (1, -1, 0), // W + A
                (0, 0, 1),  // Jump only
                (1, 0, 1),  // W + Jump
                (1, 1, 1),  // W + D + Jump
                (1, -1, 1), // W + A + Jump
            };
        }

        public static (Node best, List<Node> history, long expanded) BeamSearchMaxX(PlayerState start, Options opt)
        {
            var yawDeltas = new double[] { -opt.YawStepDeg, 0.0, +opt.YawStepDeg };
            var frontier = new List<Node> { new Node { PS = start.Clone(), Plan = new List<PlanInput>(), Score = start.Pos.X } };
            var snapshots = new List<Node>();
            long expanded = 0;

            for (int t = 0; t < opt.Frames; t++)
            {
                var next = new List<Node>(frontier.Count * opt.Combos.Count * yawDeltas.Length);
                foreach (var node in frontier)
                {
                    foreach (var c in opt.Combos)
                    {
                        foreach (var dy in yawDeltas)
                        {
                            var input = new Input { Fwd = c.fwd, Str = c.str, Jump = c.jump, YawDeltaDeg = dy };
                            var ps2 = node.PS.Clone();
                            Physics.Step(ps2, input);
                            var newNode = new Node
                            {
                                PS = ps2,
                                Plan = new List<PlanInput>(node.Plan) { new PlanInput { Fwd = c.fwd, Str = c.str, Jump = c.jump, YawDeltaDeg = dy } },
                                Score = ps2.Pos.X
                            };
                            next.Add(newNode);
                            expanded++;
                        }
                    }
                }
                // Keep best beamWidth by X distance, tie-break by X velocity
                next.Sort((a, b) =>
                {
                    int cmp = b.Score.CompareTo(a.Score);
                    if (cmp != 0)
                        return cmp;
                    return b.PS.Vel.X.CompareTo(a.PS.Vel.X);
                });
                frontier = next.Take(opt.BeamWidth).ToList();
                snapshots.Add(frontier[0]);
            }

            frontier.Sort((a, b) => b.Score.CompareTo(a.Score));
            return (frontier[0], snapshots, expanded);
        }
    }

    // ---------------------- Demo / Entry point ----------------------
    public static class Program
    {
        static void Main()
        {
            // Config
            var frames = 2500; // ~2 seconds at 125 FPS
            var opt = new Search.Options
            {
                Frames = frames,
                BeamWidth = 128,
                YawStepDeg = 0.5
            };

            Console.WriteLine($"[Q3BeamSearch] Starting search: frames={opt.Frames}, beamWidth={opt.BeamWidth}, yawStep={opt.YawStepDeg} deg");
            var start = new PlayerState();
            var (best, history, expanded) = Search.BeamSearchMaxX(start, opt);

            // Evaluate best plan for detailed stats
            var stats = EvaluatePlan(start, best.Plan);

            Console.WriteLine("[Q3BeamSearch] Search complete");
            Console.WriteLine($"  Expanded nodes: {expanded:N0}");
            Console.WriteLine($"  Best distance X: {best.PS.Pos.X:F3}u");
            Console.WriteLine($"  Final speed: {best.PS.Vel.Len():F3} u/s  | Max speed: {stats.maxSpeed:F3} u/s");
            Console.WriteLine($"  Jumps: {stats.jumps}, Ground frames: {stats.groundFrames}, Air frames: {stats.airFrames}");
            Console.WriteLine($"  Yaw: final={best.PS.YawDeg:F2}°, avgΔ/frame={stats.avgYawDelta:F3}°, leftTurns={stats.leftTurns}, rightTurns={stats.rightTurns}");

            var outFile = "movement.cfg";
            ExportToQ3Cfg(best.Plan, outFile);
            Console.WriteLine($"[Q3BeamSearch] Exported optimized config -> {outFile}");
        }

        private static (double finalX, double maxSpeed, int jumps, int groundFrames, int airFrames, double avgYawDelta, int leftTurns, int rightTurns) EvaluatePlan(PlayerState start, List<PlanInput> plan)
        {
            var ps = start.Clone();
            double maxSpeed = 0;
            int jumps = 0, ground = 0, air = 0, left = 0, right = 0;
            double yawSum = 0;
            foreach (var p in plan)
            {
                if (p.YawDeltaDeg > 0) left++;
                else if (p.YawDeltaDeg < 0) right++;
                yawSum += Math.Abs(p.YawDeltaDeg);

                var beforeGround = ps.OnGround;
                Physics.Step(ps, new Input { Fwd = p.Fwd, Str = p.Str, Jump = p.Jump, YawDeltaDeg = p.YawDeltaDeg });
                if (p.Jump == 1 && beforeGround) jumps++;
                var sp = ps.Vel.Len();
                if (sp > maxSpeed) maxSpeed = sp;
                if (ps.OnGround) ground++; else air++;
            }
            double avgYaw = plan.Count > 0 ? yawSum / plan.Count : 0;
            return (ps.Pos.X, maxSpeed, jumps, ground, air, avgYaw, left, right);
        }

        // Export plan to Quake 3 cfg with precise per-frame inputs including view turns
        static void ExportToQ3Cfg(List<PlanInput> plan, string filename)
        {
            using (var writer = new StreamWriter(filename))
            {
                writer.WriteLine("// Auto-generated by Q3BeamSearch (Defrag VQ3-like)");
                writer.WriteLine($"// FPS {Q3.FPS}, frames {plan.Count}, wait per frame");
                writer.WriteLine("// This script replays the optimized movement. /exec movement.cfg in Q3");
                writer.WriteLine();

                bool pendingJumpRelease = false;

                for (int i = 0; i < plan.Count; i++)
                {
                    var p = plan[i];

                    // Ensure +moveup pressed last frame is released at the START of this frame
                    if (pendingJumpRelease)
                    {
                        writer.WriteLine("-moveup");
                        pendingJumpRelease = false;
                    }

                    // Determine movement keys
                    var frameKeys = new List<string>();
                    if (p.Fwd > 0) frameKeys.Add("+forward");
                    else if (p.Fwd < 0) frameKeys.Add("+back");
                    if (p.Str > 0) frameKeys.Add("+moveright");
                    else if (p.Str < 0) frameKeys.Add("+moveleft");
                    if (p.Jump == 1) frameKeys.Add("+moveup");

                    // View turning per frame using cl_yawspeed and +left/+right
                    double yawDelta = p.YawDeltaDeg; // degrees this frame
                    double pitchDelta = 0; // Flat-ground movement ignores pitch in physics

                    // Convert per-frame delta to degrees per second for Q3 +left/+right/+lookup/+lookdown
                    double yawSpeedPerSec = Math.Abs(yawDelta) * Q3.FPS;
                    double pitchSpeedPerSec = Math.Abs(pitchDelta) * Q3.FPS;

                    writer.WriteLine($"seta cl_yawspeed {yawSpeedPerSec:0.###}");
                    writer.WriteLine($"seta cl_pitchspeed {pitchSpeedPerSec:0.###}");

                    if (yawDelta > 0) frameKeys.Add("+left");
                    else if (yawDelta < 0) frameKeys.Add("+right");

                    if (pitchDelta > 0) frameKeys.Add("+lookup");
                    else if (pitchDelta < 0) frameKeys.Add("+lookdown");

                    // Emit key presses for this frame
                    foreach (var key in frameKeys)
                        writer.WriteLine(key);

                    // One frame
                    writer.WriteLine("wait");

                    // Release keys pressed for this frame (except moveup which is delayed by one frame)
                    foreach (var key in frameKeys)
                    {
                        if (key == "+moveup")
                        {
                            pendingJumpRelease = true; // release at the start of next frame
                        }
                        else
                        {
                            writer.WriteLine(key.Replace("+", "-"));
                        }
                    }
                }

                // Final cleanup release
                writer.WriteLine("-forward;-moveleft;-moveright;-back;-attack;-moveup;-left;-right;-lookup;-lookdown");
            }
        }
    }
}

/*
How to run
----------
1) Create a folder and open a terminal in it.
2) dotnet new console -n Q3BeamSearch
3) Replace the generated Program.cs with this file's contents (inside the Q3BeamSearch project).
4) dotnet run --project Q3BeamSearch

Knobs to tweak
--------------
- Search.Options.Frames       : how many frames to optimize.
- Search.Options.BeamWidth    : survivors per generation (exploration vs speed).
- Search.Options.YawStepDeg   : per-frame mouse-turn step.
- Search.Options.Combos       : movement key combos to allow.
- Q3 constants (accelerate, friction, gravity, etc.) to mirror desired rulesets.
*/
