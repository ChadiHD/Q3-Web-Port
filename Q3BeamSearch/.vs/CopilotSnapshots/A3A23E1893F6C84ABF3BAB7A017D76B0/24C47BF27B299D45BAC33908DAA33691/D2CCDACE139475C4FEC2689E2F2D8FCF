using Microsoft.AspNetCore.SignalR;
using Newtonsoft.Json;
using Q3BeamSearch.Hubs;

namespace Q3BeamSearch.Services
{
    public class DemoSimulationService
    {
        private readonly IHubContext<SimulationHub> _hub;
        private readonly IWebHostEnvironment _env;

        public DemoSimulationService(IHubContext<SimulationHub> hub, IWebHostEnvironment env)
        {
            _hub = hub;
            _env = env;
        }

        public async Task RunSimulationAndSaveDemo(string connectionId, double targetMaxSpeed, int targetJumps)
        {
            Physics.UseAirWishCap = false;
            var ps = new PlayerState();
            int frames = 2500;
            int frame = 0;
            const double maxYawPerFrame = 5.0;
            int jumpCooldown = 8;
            int sinceJump = jumpCooldown;

            var demoFrames = new List<object>(frames);

            while (frame < frames)
            {
                sbyte str = (sbyte)(((frame / 30) % 2 == 0) ? 1 : -1);
                double yawDelta = StrafeGuidance.YawDeltaToDOpt(ps, 1, str, maxYawPerFrame);
                bool willJump = ps.OnGround && sinceJump >= jumpCooldown;

                var input = new Input { Fwd = 1, Str = str, Jump = (byte)(willJump ? 1 : 0), YawDeltaDeg = yawDelta };
                Physics.Step(ps, input);
                sinceJump = willJump ? 0 : sinceJump + 1;

                double speedXY = Math.Sqrt(ps.Vel.X * ps.Vel.X + ps.Vel.Y * ps.Vel.Y);

                var dto = new
                {
                    frame,
                    x = ps.Pos.X,
                    y = ps.Pos.Y,
                    z = ps.Pos.Z,
                    speed = speedXY,
                    onGround = ps.OnGround,
                    yawDeg = ps.YawDeg
                };

                demoFrames.Add(dto);
                await _hub.Clients.Client(connectionId).SendAsync("frame", dto);

                frame++;
            }

            string demosDir = Path.Combine(_env.ContentRootPath, "wwwroot", "demos");
            Directory.CreateDirectory(demosDir);
            string fileName = $"demo_{DateTime.UtcNow:yyyyMMdd_HHmmss}.json";
            string filePath = Path.Combine(demosDir, fileName);
            var json = JsonConvert.SerializeObject(demoFrames, Formatting.None);
            await File.WriteAllTextAsync(filePath, json);

            await _hub.Clients.Client(connectionId).SendAsync("demoSaved", fileName);
        }

        public async Task PlayDemoToClient(string connectionId, string fileName)
        {
            string path = Path.Combine(_env.ContentRootPath, "wwwroot", "demos", fileName);
            if (!File.Exists(path)) return;
            var json = await File.ReadAllTextAsync(path);
            var frames = Newtonsoft.Json.JsonConvert.DeserializeObject<List<dynamic>>(json) ?? new();
            foreach (var f in frames)
            {
                await _hub.Clients.Client(connectionId).SendAsync("frame", f);
            }
        }
    }
}
