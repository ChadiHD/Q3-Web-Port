using Microsoft.AspNetCore.SignalR;
using Q3BeamSearch.Services;

namespace Q3BeamSearch.Hubs
{
    public class SimulationHub : Hub
    {
        private readonly DemoSimulationService _service;
        public SimulationHub(DemoSimulationService service)
        {
            _service = service;
        }

        public override Task OnConnectedAsync()
        {
            // Optionally handle when a client connects
            return base.OnConnectedAsync();
        }
        public override Task OnDisconnectedAsync(Exception? exception)
        {
            // Optionally handle when a client disconnects
            return base.OnDisconnectedAsync(exception);
        }

        public async Task StartSimulation(double targetMaxSpeed, int targetJumps)
        {
            await _service.RunSimulationAndSaveDemo(Context.ConnectionId, targetMaxSpeed, targetJumps);
        }

        public async Task PlayDemo(string fileName)
        {
            await _service.PlayDemoToClient(Context.ConnectionId, fileName);
        }

        // You can add more methods here to handle client requests if needed
    }
}
