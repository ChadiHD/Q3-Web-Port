using System.Collections.Generic;
using System.IO;

namespace Q3BeamSearch.Export
{
    public static class Q3CfgExporter
    {
        // Export cfg with jump pulses at landing (using estimated 48u air time)
        public static void Export(List<Q3BeamSearch.Input> inputs, string filename, int maxJumps, int airFrames48)
        {
            using var writer = new StreamWriter(filename);

            writer.WriteLine("// Auto-generated by Q3 Optimizer (auto-timed jumps)");
            writer.WriteLine($"// FPS {Q3BeamSearch.Q3.FPS}, frames {inputs.Count}, estimated air frames (48u): {airFrames48}");
            writer.WriteLine();

            bool leftHeld = false, rightHeld = false;
            bool forwardHeld = false, backHeld = false, moveLeftHeld = false, moveRightHeld = false;
            int jumpsDone = 0;

            int i = 0;
            while (i < inputs.Count)
            {
                var cmds = new List<string>();
                var inp = inputs[i];

                // Movement keys
                if (inp.Fwd > 0 && !forwardHeld) { cmds.Add("+forward"); forwardHeld = true; }
                if (inp.Fwd <= 0 && forwardHeld) { cmds.Add("-forward"); forwardHeld = false; }
                if (inp.Fwd < 0 && !backHeld) { cmds.Add("+back"); backHeld = true; }
                if (inp.Fwd >= 0 && backHeld) { cmds.Add("-back"); backHeld = false; }

                if (inp.Str > 0 && !moveRightHeld) { cmds.Add("+moveright"); moveRightHeld = true; }
                if (inp.Str <= 0 && moveRightHeld) { cmds.Add("-moveright"); moveRightHeld = false; }
                if (inp.Str < 0 && !moveLeftHeld) { cmds.Add("+moveleft"); moveLeftHeld = true; }
                if (inp.Str >= 0 && moveLeftHeld) { cmds.Add("-moveleft"); moveLeftHeld = false; }

                if (System.Math.Abs(inp.YawDeltaDeg) > 1e-6)
                {
                    double yawSpeedPerSec = System.Math.Abs(inp.YawDeltaDeg) * Q3BeamSearch.Q3.FPS;
                    cmds.Add($"seta cl_yawspeed {yawSpeedPerSec:0.###}");
                    if (inp.YawDeltaDeg > 0 && !leftHeld) { cmds.Add("+left"); leftHeld = true; }
                    if (inp.YawDeltaDeg < 0 && !rightHeld) { cmds.Add("+right"); rightHeld = true; }
                }
                else
                {
                    if (leftHeld) { cmds.Add("-left"); leftHeld = false; }
                    if (rightHeld) { cmds.Add("-right"); rightHeld = false; }
                }

                if (inp.Jump == 1 && jumpsDone < maxJumps)
                {
                    // Pulse jump now
                    cmds.Add("+moveup");
                    cmds.Add("wait 2");
                    cmds.Add("-moveup");
                    writer.WriteLine(string.Join(";", cmds));
                    cmds.Clear();

                    // Wait until landing then continue (estimate)
                    int waitFrames = System.Math.Min(airFrames48, inputs.Count - (i + 1));
                    if (waitFrames > 0)
                    {
                        writer.WriteLine($"wait {waitFrames * 2}");
                        i += waitFrames;
                    }
                    jumpsDone++;
                    continue;
                }

                cmds.Add("wait 2");
                writer.WriteLine(string.Join(";", cmds));
                i++;
            }

            // Release held keys
            var tail = new List<string>();
            if (leftHeld) tail.Add("-left");
            if (rightHeld) tail.Add("-right");
            if (forwardHeld) tail.Add("-forward");
            if (backHeld) tail.Add("-back");
            if (moveRightHeld) tail.Add("-moveright");
            if (moveLeftHeld) tail.Add("-moveleft");
            if (tail.Count > 0) writer.WriteLine(string.Join(";", tail));
        }
    }
}