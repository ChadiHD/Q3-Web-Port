<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Q3 Movement 3D Viewer - Q3 Physics Enhanced</title>
    <!-- Q3 Physics WebAssembly Module -->
    <script src="../js/q3physics.js"></script>
    <!-- External Stylesheet -->
    <link rel="stylesheet" href="../css/viewer3d.css">
</head>
<body>
    <div class="viewer-container">
        <div id="threejs-container"></div>

        <button class="back-button" onclick="window.history.back()">← Back to Charts</button>

        <!-- Frame Editor Toggle Button -->
        <button id="btnFrameEditor" class="mode-toggle-button" style="top: 80px;">📝 Frame Editor</button>
        
        <!-- Waypoint Editor Toggle Button -->
        <button id="btnWaypointEditor" class="mode-toggle-button" style="top: 130px;">📍 Waypoints</button>

        <div class="controls-overlay">
            <h3>3D Movement Controls</h3>

            <div class="control-group">
                <div class="control-row">
                    <label>Frame:</label>
                    <input type="range" id="frameSlider" min="0" max="100" value="0" step="1">
                    <div id="frameDisplay" class="frame-display">0 / 0</div>
                </div>
            </div>

            <div class="control-group">
                <div class="control-row">
                    <button id="btnFirst">⏮</button>
                    <button id="btnPrev">⏴</button>
                    <button id="btnPlay">⏯</button>
                    <button id="btnNext">⏵</button>
                    <button id="btnLast">⏭</button>
                    <select id="playbackSpeed">
                        <option value="0.10">0.10x</option>
                        <option value="0.25">0.25x</option>
                        <option value="0.5">0.5x</option>
                        <option value="1" selected>1x</option>
                        <option value="2">2x</option>
                        <option value="4">4x</option>
                    </select>
                </div>
            </div>

            <div class="control-group">
                <label>Map Controls:</label>
                <div class="control-row">
                    <input type="file" id="bspFileInput" accept=".bsp,.pk3" style="display: none;">
                    <button id="loadBspButton">Load BSP/PK3 Map</button>
                    <button id="toggleWireframe">Toggle Wireframe</button>
                </div>
            </div>

            <div class="control-group">
                <label>Map Brightness: <span id="brightnessValue">100</span>%</label>
                <div class="control-row">
                    <input type="range" id="brightnessSlider" min="10" max="300" value="100" step="10" style="flex: 1;">
                    <button id="resetBrightness" style="flex: 0;">Reset</button>
                </div>
                <div style="font-size: 11px; color: #888; margin-top: 5px;">
                    Adjusts ambient and directional lighting intensity
                </div>
            </div>

            <div class="control-group">
                <label>Movement Visualization:</label>
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label><input type="checkbox" id="showPath" checked> Movement Path</label>
                    <label><input type="checkbox" id="showVelocity" checked> Velocity Vector</label>
                    <label><input type="checkbox" id="showYaw" checked> View Direction</label>
                    <label><input type="checkbox" id="showWish" checked> Wish Direction</label>
                    <label><input type="checkbox" id="showGround" checked> Ground Contact</label>
                    <label><input type="checkbox" id="showTrail" checked> Trail Effect</label>
                </div>
            </div>

            <div class="control-group">
                <label>Map Elements:</label>
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label><input type="checkbox" id="showMap" checked> BSP Map</label>
                    <label><input type="checkbox" id="showSpawns" checked> Player Spawns</label>
                    <label><input type="checkbox" id="showTriggers" checked> Triggers</label>
                    <label><input type="checkbox" id="showItems" checked> Items</label>
                </div>
            </div>

            <div class="control-group">
                <div class="control-row">
                    <button id="resetCamera">Reset Camera</button>
                    <button id="topView">Top View</button>
                    <button id="sideView">Side View</button>
                </div>
            </div>
        </div>

        <div class="info-panel">
            <h4>Current Frame Info</h4>
            <div class="info-item">
                <span class="info-label">Frame:</span>
                <span class="info-value" id="infoFrame">0</span>
            </div>
            <div class="info-item">
                <span class="info-label">Speed:</span>
                <span class="info-value" id="infoSpeed">0 ups</span>
            </div>
            <div class="info-item">
                <span class="info-label">Position:</span>
                <span class="info-value" id="infoPosition">0, 0, 0</span>
            </div>
            <div class="info-item">
                <span class="info-label">Yaw:</span>
                <span class="info-value" id="infoYaw">0 degrees</span>
            </div>
            <div class="info-item">
                <span class="info-label">Ground:</span>
                <span class="info-value" id="infoGround">No</span>
            </div>
            <div class="info-item">
                <span class="info-label">Height:</span>
                <span class="info-value" id="infoHeight">0</span>
            </div>
        </div>

        <!-- Waypoint Info Panel -->
        <div id="waypointPanel" class="waypoint-panel" style="display: none;">
            <h4>Waypoint System</h4>
            <div class="info-item">
                <span class="info-label">Total:</span>
                <span class="info-value" id="waypointTotal">0</span>
            </div>
            <div class="info-item">
                <span class="info-label">Reached:</span>
                <span class="info-value" id="waypointReached">0</span>
            </div>
            <div class="info-item">
                <span class="info-label">Current:</span>
                <span class="info-value" id="waypointCurrent">-</span>
            </div>
            <div class="info-item">
                <span class="info-label">Total Time:</span>
                <span class="info-value" id="waypointTime">-</span>
            </div>
            <div style="margin-top: 10px; display: flex; gap: 5px; flex-direction: column;">
                <button id="btnResetWaypoints" style="width: 100%;">Reset Waypoints</button>
                <button id="btnClearWaypoints" style="width: 100%;">Clear All</button>
                <button id="btnExportWaypoints" style="width: 100%;">Export JSON</button>
                <button id="btnImportWaypoints" style="width: 100%;">Import JSON</button>
            </div>
            <div id="waypointSplits" style="margin-top: 10px; max-height: 200px; overflow-y: auto;">
                <h5 style="margin: 5px 0;">Splits:</h5>
                <div id="waypointSplitsList" style="font-size: 11px;"></div>
            </div>
        </div>

        <div class="entity-info">
            <h4>Map Entities</h4>
            <div id="entityCount">Loading...</div>
        </div>

        <div class="legend">
            <h4>Legend</h4>
            <div class="legend-item">
                <div class="legend-color" style="background: #4fc3f7;"></div>
                <span>Movement Path</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #ff6b6b;"></div>
                <span>Current Position</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #4caf50;"></div>
                <span>Velocity Vector</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #ff9800;"></div>
                <span>View Direction</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #9c27b0;"></div>
                <span>Wish Direction (Q3)</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #f44336;"></div>
                <span>Ground Contact</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #00ff00;"></div>
                <span>Player Spawns</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #ffff00;"></div>
                <span>Triggers</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #00ffff;"></div>
                <span>Items</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background: #ff0000;"></div>
                <span>Waypoints</span>
            </div>
        </div>
    </div>

    <!-- Import maps for Three.js -->
    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/",
            "jszip": "https://cdn.skypack.dev/jszip@3.10.1"
        }
    }
    </script>

    <!-- External JavaScript Module -->
    <script type="module" src="../js/viewer3d.js"></script>
</body>
</html>