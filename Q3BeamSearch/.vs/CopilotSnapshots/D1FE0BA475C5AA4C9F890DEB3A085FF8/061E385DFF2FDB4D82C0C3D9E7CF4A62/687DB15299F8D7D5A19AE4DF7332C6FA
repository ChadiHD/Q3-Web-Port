// wwwroot/js/frame-editor.js
// Frame-by-Frame Editor with Q3 Physics Integration

export class FrameEditor {
    constructor(q3Physics) {
        this.Q3Physics = q3Physics;
        this.frames = [];
        this.currentFrame = 0;
        this.playerState = this.initializeState();
        this.isEditing = false;
        this.undoStack = [];
        this.redoStack = [];
        this.maxUndoStack = 50;
    }
    
    initializeState() {
        return {
            pos: { x: 0, y: 0, z: 24 },
            vel: { x: 0, y: 0, z: 0 },
            angles: { pitch: 0, yaw: 0, roll: 0 },
            onGround: false,
            buttons: 0
        };
    }
    
    // Create a new frame with input
    addFrame(input, usePhysics = true) {
        const frame = {
            index: this.frames.length,
            input: {
                forwardMove: input.forwardMove || 0,   // -127 to 127
                rightMove: input.rightMove || 0,       // -127 to 127
                upMove: input.upMove || 0,             // 0 or 200 (jump)
                angles: input.angles || [0, 0, 0],     // [pitch, yaw, roll]
                buttons: input.buttons || 0            // bitfield for jump, etc
            },
            stateBefore: this.cloneState(this.playerState),
            stateAfter: null
        };
        
        // Simulate with real Q3 physics
        if (usePhysics && this.Q3Physics) {
            frame.stateAfter = this.simulateFrameQ3(this.playerState, frame.input);
        } else {
            frame.stateAfter = this.simulateFrameFallback(this.playerState, frame.input);
        }
        
        this.frames.push(frame);
        this.playerState = frame.stateAfter;
        
        // Save to undo stack
        this.saveToUndo();
        
        return frame;
    }
    
    // Simulate one frame using Q3 Physics WASM
    simulateFrameQ3(state, input) {
        try {
            // Convert state to Q3 format
            const pos = [state.pos.x, state.pos.y, state.pos.z];
            const vel = [state.vel.x, state.vel.y, state.vel.z];
            const angles = [state.angles.pitch, state.angles.yaw, state.angles.roll];
            
            // Call Q3 WASM PmoveSingle
            const result = this.Q3Physics.ccall('PmoveSingle', 'number', 
                ['array', 'array', 'array', 'number', 'number', 'number', 'number', 'number'],
                [pos, vel, angles, input.forwardMove, input.rightMove, input.upMove, input.buttons, 1/125.0]
            );
            
            // Get updated state
            const newPos = this.Q3Physics.ccall('GetPlayerPosition', 'array', [], []);
            const newVel = this.Q3Physics.ccall('GetPlayerVelocity', 'array', [], []);
            const newAngles = this.Q3Physics.ccall('GetPlayerAngles', 'array', [], []);
            const onGround = this.Q3Physics.ccall('IsPlayerOnGround', 'number', [], []) === 1;
            
            return {
                pos: { x: newPos[0], y: newPos[1], z: newPos[2] },
                vel: { x: newVel[0], y: newVel[1], z: newVel[2] },
                angles: { pitch: newAngles[0], yaw: newAngles[1], roll: newAngles[2] },
                onGround: onGround,
                buttons: input.buttons
            };
        } catch (error) {
            console.warn('[FrameEditor] Q3 Physics failed, using fallback:', error);
            return this.simulateFrameFallback(state, input);
        }
    }
    
    // Fallback simulation (simplified physics)
    simulateFrameFallback(state, input) {
        const dt = 1/125.0; // 125 FPS
        const newState = this.cloneState(state);
        
        // Convert input to movement vector
        const yawRad = (state.angles.yaw * Math.PI) / 180;
        const forward = { x: Math.cos(yawRad), y: Math.sin(yawRad), z: 0 };
        const right = { x: -Math.sin(yawRad), y: Math.cos(yawRad), z: 0 };
        
        // Apply movement
        const speed = 320; // Default player speed
        const wishVel = {
            x: forward.x * (input.forwardMove / 127) * speed + right.x * (input.rightMove / 127) * speed,
            y: forward.y * (input.forwardMove / 127) * speed + right.y * (input.rightMove / 127) * speed,
            z: 0
        };
        
        // Simple acceleration (not accurate to Q3)
        const accel = state.onGround ? 10 : 1;
        newState.vel.x += (wishVel.x - newState.vel.x) * accel * dt;
        newState.vel.y += (wishVel.y - newState.vel.y) * accel * dt;
        
        // Apply gravity
        if (!state.onGround) {
            newState.vel.z -= 800 * dt; // Gravity
        }
        
        // Jump
        if (input.upMove > 0 && state.onGround) {
            newState.vel.z = 270; // Jump velocity
            newState.onGround = false;
        }
        
        // Integrate position
        newState.pos.x += newState.vel.x * dt;
        newState.pos.y += newState.vel.y * dt;
        newState.pos.z += newState.vel.z * dt;
        
        // Ground detection
        if (newState.pos.z <= 24) {
            newState.pos.z = 24;
            newState.vel.z = 0;
            newState.onGround = true;
        } else {
            newState.onGround = false;
        }
        
        // Update angles from input
        newState.angles.yaw = input.angles[1];
        newState.angles.pitch = input.angles[0];
        newState.angles.roll = input.angles[2];
        
        return newState;
    }
    
    // Edit existing frame
    updateFrame(index, newInput) {
        if (index < 0 || index >= this.frames.length) return;
        
        this.saveToUndo();
        this.frames[index].input = newInput;
        this.resimulateFrom(index);
    }
    
    // Insert frame at index
    insertFrame(index, input) {
        this.saveToUndo();
        
        // Reset to previous state
        if (index > 0) {
            this.playerState = this.cloneState(this.frames[index - 1].stateAfter);
        } else {
            this.playerState = this.initializeState();
        }
        
        // Create new frame
        const frame = {
            index: index,
            input: input,
            stateBefore: this.cloneState(this.playerState),
            stateAfter: null
        };
        
        frame.stateAfter = this.simulateFrameQ3(this.playerState, frame.input);
        
        // Insert into array
        this.frames.splice(index, 0, frame);
        
        // Reindex and resimulate
        this.reindexFrames();
        this.resimulateFrom(index + 1);
    }
    
    // Delete frame
    deleteFrame(index) {
        if (index < 0 || index >= this.frames.length) return;
        
        this.saveToUndo();
        this.frames.splice(index, 1);
        this.reindexFrames();
        
        if (index < this.frames.length) {
            this.resimulateFrom(index);
        }
    }
    
    // Resimulate all frames from startIndex forward
    resimulateFrom(startIndex) {
        // Reset to state before startIndex
        if (startIndex > 0) {
            this.playerState = this.cloneState(this.frames[startIndex - 1].stateAfter);
        } else {
            this.playerState = this.initializeState();
        }
        
        // Resimulate all subsequent frames
        for (let i = startIndex; i < this.frames.length; i++) {
            this.frames[i].stateBefore = this.cloneState(this.playerState);
            this.frames[i].stateAfter = this.simulateFrameQ3(this.playerState, this.frames[i].input);
            this.playerState = this.frames[i].stateAfter;
        }
    }
    
    // Undo/Redo
    saveToUndo() {
        const state = {
            frames: JSON.parse(JSON.stringify(this.frames)),
            currentFrame: this.currentFrame
        };
        this.undoStack.push(state);
        
        if (this.undoStack.length > this.maxUndoStack) {
            this.undoStack.shift();
        }
        
        this.redoStack = []; // Clear redo stack on new action
    }
    
    undo() {
        if (this.undoStack.length === 0) return false;
        
        const currentState = {
            frames: JSON.parse(JSON.stringify(this.frames)),
            currentFrame: this.currentFrame
        };
        this.redoStack.push(currentState);
        
        const previousState = this.undoStack.pop();
        this.frames = previousState.frames;
        this.currentFrame = previousState.currentFrame;
        
        return true;
    }
    
    redo() {
        if (this.redoStack.length === 0) return false;
        
        this.saveToUndo();
        
        const nextState = this.redoStack.pop();
        this.frames = nextState.frames;
        this.currentFrame = nextState.currentFrame;
        
        return true;
    }
    
    // Utility functions
    cloneState(state) {
        return {
            pos: { ...state.pos },
            vel: { ...state.vel },
            angles: { ...state.angles },
            onGround: state.onGround,
            buttons: state.buttons
        };
    }
    
    reindexFrames() {
        this.frames.forEach((frame, index) => {
            frame.index = index;
        });
    }
    
    // Export to various formats
    exportToCfg() {
        let cfg = "// Q3 Movement Script\n";
        cfg += "// Generated by Frame Editor\n\n";
        
        this.frames.forEach((frame, i) => {
            cfg += `// Frame ${i}\n`;
            cfg += `+forward ${frame.input.forwardMove}\n`;
            cfg += `+moveright ${frame.input.rightMove}\n`;
            
            if (frame.input.upMove > 0) {
                cfg += `+moveup\n`;
            }
            
            cfg += `viewangles ${frame.input.angles[0]} ${frame.input.angles[1]} ${frame.input.angles[2]}\n`;
            cfg += `wait\n\n`;
        });
        
        return cfg;
    }
    
    exportToJSON() {
        const data = this.frames.map(frame => ({
            frame: frame.index,
            x: frame.stateAfter.pos.x,
            y: frame.stateAfter.pos.y,
            z: frame.stateAfter.pos.z,
            speed: Math.sqrt(
                frame.stateAfter.vel.x ** 2 + 
                frame.stateAfter.vel.y ** 2 + 
                frame.stateAfter.vel.z ** 2
            ),
            yawDeg: frame.stateAfter.angles.yaw,
            onGround: frame.stateAfter.onGround,
            forwardMove: frame.input.forwardMove,
            rightMove: frame.input.rightMove,
            upMove: frame.input.upMove,
            buttons: frame.input.buttons
        }));
        
        return JSON.stringify(data, null, 2);
    }
    
    // Import from JSON
    importFromJSON(jsonData) {
        try {
            const data = JSON.parse(jsonData);
            this.frames = [];
            this.playerState = this.initializeState();
            
            data.forEach(frameData => {
                const input = {
                    forwardMove: frameData.forwardMove || 0,
                    rightMove: frameData.rightMove || 0,
                    upMove: frameData.upMove || 0,
                    angles: [0, frameData.yawDeg || 0, 0],
                    buttons: frameData.buttons || 0
                };
                
                this.addFrame(input, false); // Don't resimulate, use provided data
            });
            
            return true;
        } catch (error) {
            console.error('[FrameEditor] Import failed:', error);
            return false;
        }
    }
    
    // Get stats
    getStats() {
        if (this.frames.length === 0) return null;
        
        let maxSpeed = 0;
        let totalDistance = 0;
        let jumps = 0;
        
        this.frames.forEach((frame, i) => {
            const speed = Math.sqrt(
                frame.stateAfter.vel.x ** 2 + 
                frame.stateAfter.vel.y ** 2 + 
                frame.stateAfter.vel.z ** 2
            );
            maxSpeed = Math.max(maxSpeed, speed);
            
            if (i > 0) {
                const dx = frame.stateAfter.pos.x - this.frames[i-1].stateAfter.pos.x;
                const dy = frame.stateAfter.pos.y - this.frames[i-1].stateAfter.pos.y;
                const dz = frame.stateAfter.pos.z - this.frames[i-1].stateAfter.pos.z;
                totalDistance += Math.sqrt(dx*dx + dy*dy + dz*dz);
                
                // Count jumps (ground to air transition)
                if (this.frames[i-1].stateAfter.onGround && !frame.stateAfter.onGround) {
                    jumps++;
                }
            }
        });
        
        const lastFrame = this.frames[this.frames.length - 1];
        const finalSpeed = Math.sqrt(
            lastFrame.stateAfter.vel.x ** 2 + 
            lastFrame.stateAfter.vel.y ** 2 + 
            lastFrame.stateAfter.vel.z ** 2
        );
        
        return {
            totalFrames: this.frames.length,
            duration: (this.frames.length / 125.0).toFixed(2) + 's',
            maxSpeed: maxSpeed.toFixed(1) + ' ups',
            finalSpeed: finalSpeed.toFixed(1) + ' ups',
            totalDistance: totalDistance.toFixed(1),
            jumps: jumps
        };
    }
}