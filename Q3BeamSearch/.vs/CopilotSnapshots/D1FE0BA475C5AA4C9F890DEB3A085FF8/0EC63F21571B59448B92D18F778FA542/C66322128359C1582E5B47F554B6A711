// va() - variable argument string formatting
char *QDECL va(char *format, ...) {
    static char string[2][32000];
    static int index = 0;
    char *buf;
    va_list ap;

    buf = string[index & 1];
    index++;

    va_start(ap, format);
    vsnprintf(buf, sizeof(string[0]), format, ap);
    va_end(ap);

    return buf;
}

// Q_stricmp - case-insensitive string compare (used by BG_FindItem in bg_misc.c)
int Q_stricmp(const char *s1, const char *s2) {
    unsigned char c1, c2;
    if (s1 == NULL) return s2 == NULL ? 0 : -1;
    if (s2 == NULL) return 1;
    do {
        c1 = *s1++;
        c2 = *s2++;
        if (c1 >= 'A' && c1 <= 'Z') c1 += 'a' - 'A';
        if (c2 >= 'A' && c2 <= 'Z') c2 += 'a' - 'A';
        if (c1 != c2) return c1 < c2 ? -1 : 1;
    } while (c1);
    return 0;
}

// vectoangles - convert direction vector to angles (used by BG_TouchJumpPad)
void vectoangles(const vec3_t value1, vec3_t angles) {
    float forward;
    float yaw, pitch;

    if (value1[1] == 0 && value1[0] == 0) {
        yaw = 0;
        pitch = value1[2] > 0 ? 90 : 270;
    } else {
        if (value1[0]) {
            yaw = (atan2(value1[1], value1[0]) * 180 / M_PI);
        } else if (value1[1] > 0) {
            yaw = 90;
        } else {
            yaw = 270;
        }
        if (yaw < 0) yaw += 360;

        forward = sqrt(value1[0] * value1[0] + value1[1] * value1[1]);
        pitch = (atan2(value1[2], forward) * 180 / M_PI);
        if (pitch < 0) pitch += 360;
    }

    angles[PITCH] = -pitch;
    angles[YAW] = yaw;
    angles[ROLL] = 0;
}

// AngleNormalize180 - normalize angle to [-180, 180] (used by BG_TouchJumpPad)
float AngleNormalize180(float angle) {
    angle = fmodf(angle, 360.0f);
    if (angle > 180.0f) angle -= 360.0f;
    if (angle < -180.0f) angle += 360.0f;
    return angle;
}