// va() - variable argument string formatting
char *QDECL va(char *format, ...) {
    static char string[2][32000]; // in case va is called by nested functions
    static int index = 0;
    char *buf;
    va_list ap;

    buf = string[index & 1];
    index++;

    va_start(ap, format);
    vsnprintf(buf, sizeof(string[0]), format, ap);
    va_end(ap);

    return buf;
}

// Q_stricmp - case-insensitive string compare
int Q_stricmp(const char *s1, const char *s2) {
    unsigned char c1, c2;
    do {
        c1 = *s1++;
        c2 = *s2++;
        if (c1 >= 'A' && c1 <= 'Z') c1 += 'a' - 'A';
        if (c2 >= 'A' && c2 <= 'Z') c2 += 'a' - 'A';
        if (c1 != c2) return c1 < c2 ? -1 : 1;
    } while (c1);
    return 0;
}

// Com_sprintf
void QDECL Com_sprintf(char *dest, int size, const char *fmt, ...) {
    va_list ap;
    va_start(ap, fmt);
    vsnprintf(dest, size, fmt, ap);
    va_end(ap);
}