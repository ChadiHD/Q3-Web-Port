<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Q3 TAS Viewer v2 — oDFe Physics</title>
    <script src="../js/q3physics.js"></script>
    <link rel="stylesheet" href="../css/viewer3d-v2.css">
</head>
<body>
    <!-- ═══════════ MAP UPLOAD GATE (shown first) ═══════════ -->
    <div id="uploadGate" class="upload-gate">
        <div class="upload-gate-inner">
            <h1>Q3 TAS Viewer <small>v2</small></h1>
            <p class="subtitle">Upload a Quake&nbsp;3 map to begin</p>

            <div id="dropZone" class="drop-zone">
                <div class="drop-zone-icon">&#x1F5FA;&#xFE0F;</div>
                <div class="drop-zone-text">Drop a <b>.bsp</b> or <b>.pk3</b> map here</div>
                <div class="drop-zone-or">&#x2014; or &#x2014;</div>
                <button id="btnBrowseMap" class="btn-primary">Browse Files</button>
                <input type="file" id="mapFileInput" accept=".bsp,.pk3" style="display:none">
            </div>

            <div id="uploadStatus" class="upload-status"></div>
        </div>
    </div>

    <!-- ═══════════ MAIN VIEWER (hidden until map loaded) ═══════════ -->
    <div id="viewerRoot" class="viewer-container" style="display:none">
        <div id="threejs-container"></div>

        <!-- Top bar -->
        <div class="top-bar">
            <button id="btnLoadNewMap" title="Load different map">&#x1F5FA;&#xFE0F; Map</button>
            <button id="btnLoadDemo" title="Load a demo (.dm_68 / JSON)">&#x1F3AC; Demo</button>
            <input type="file" id="demoFileInput" accept=".dm_68,.json" style="display:none">
            <button id="btnLoadScript" title="Load a movement script (.cfg)">&#x1F4DC; Script</button>
            <input type="file" id="scriptFileInput" accept=".cfg,.txt" style="display:none">
            <span class="separator"></span>
            <button id="btnFrameEditor" class="toggle-btn" title="Frame-by-frame editor">&#x1F4DD; Editor</button>
            <button id="btnWaypointEditor" class="toggle-btn" title="Place waypoints">&#x1F4CD; Waypoints</button>
            <button id="btnOptimize" class="toggle-btn" title="Run optimizer on waypoint route">&#x26A1; Optimize</button>
            <span class="separator"></span>
            <button id="btnScriptEditor" class="toggle-btn" title="Write a movement script">&#x270F;&#xFE0F; Script Editor</button>
        </div>

        <!-- Left panel: controls -->
        <div class="controls-overlay" id="controlsPanel">
            <h3>Controls</h3>

            <!-- Playback -->
            <div class="control-group">
                <div class="control-row">
                    <label>Frame:</label>
                    <input type="range" id="frameSlider" min="0" max="0" value="0" step="1">
                    <div id="frameDisplay" class="frame-display">0 / 0</div>
                </div>
                <div class="control-row">
                    <button id="btnFirst">&#x23EE;</button>
                    <button id="btnPrev">&#x23F4;</button>
                    <button id="btnPlay">&#x23EF;</button>
                    <button id="btnNext">&#x23F5;</button>
                    <button id="btnLast">&#x23ED;</button>
                    <select id="playbackSpeed">
                        <option value="0.10">0.10×</option>
                        <option value="0.25">0.25×</option>
                        <option value="0.5">0.5×</option>
                        <option value="1" selected>1×</option>
                        <option value="2">2×</option>
                        <option value="4">4×</option>
                    </select>
                </div>
            </div>

            <!-- Map -->
            <div class="control-group">
                <label>Map Brightness: <span id="brightnessValue">100</span>%</label>
                <div class="control-row">
                    <input type="range" id="brightnessSlider" min="10" max="300" value="100" step="10" style="flex:1">
                    <button id="resetBrightness" style="flex:0">Reset</button>
                </div>
            </div>

            <!-- Viz toggles -->
            <div class="control-group">
                <label>Visualization:</label>
                <div class="toggle-grid">
                    <label><input type="checkbox" id="showPath" checked> Path</label>
                    <label><input type="checkbox" id="showVelocity" checked> Velocity</label>
                    <label><input type="checkbox" id="showYaw" checked> Yaw</label>
                    <label><input type="checkbox" id="showWish" checked> Wish</label>
                    <label><input type="checkbox" id="showGround" checked> Ground</label>
                    <label><input type="checkbox" id="showTrail" checked> Trail</label>
                </div>
            </div>

            <div class="control-group">
                <label>Map Elements:</label>
                <div class="toggle-grid">
                    <label><input type="checkbox" id="showMap" checked> Map</label>
                    <label><input type="checkbox" id="showSpawns" checked> Spawns</label>
                    <label><input type="checkbox" id="showTriggers" checked> Triggers</label>
                    <label><input type="checkbox" id="showItems" checked> Items</label>
                </div>
            </div>

            <div class="control-group">
                <div class="control-row">
                    <button id="toggleWireframe">Wireframe</button>
                    <button id="resetCamera">Reset Cam</button>
                    <button id="topView">Top</button>
                    <button id="sideView">Side</button>
                </div>
            </div>
        </div>

        <!-- Right panel: info -->
        <div class="info-panel" id="infoPanel">
            <h4>Frame Info</h4>
            <div class="info-item"><span class="info-label">Frame:</span><span class="info-value" id="infoFrame">—</span></div>
            <div class="info-item"><span class="info-label">Speed:</span><span class="info-value" id="infoSpeed">—</span></div>
            <div class="info-item"><span class="info-label">Position:</span><span class="info-value" id="infoPosition">—</span></div>
            <div class="info-item"><span class="info-label">Yaw:</span><span class="info-value" id="infoYaw">—</span></div>
            <div class="info-item"><span class="info-label">Ground:</span><span class="info-value" id="infoGround">—</span></div>
            <div class="info-item"><span class="info-label">Height:</span><span class="info-value" id="infoHeight">—</span></div>
            <div class="info-item"><span class="info-label">H-Speed:</span><span class="info-value" id="infoHSpeed">—</span></div>
            <h4 style="margin-top:12px">Map Entities</h4>
            <div id="entityCount" style="font-size:12px;color:#aaa">—</div>
        </div>

        <!-- Waypoint panel (bottom-left, hidden until waypoint mode) -->
        <div id="waypointPanel" class="waypoint-panel" style="display:none">
            <h4>Waypoints</h4>
            <div class="info-item"><span class="info-label">Total:</span><span class="info-value" id="waypointTotal">0</span></div>
            <div class="info-item"><span class="info-label">Reached:</span><span class="info-value" id="waypointReached">0</span></div>
            <div class="info-item"><span class="info-label">Time:</span><span class="info-value" id="waypointTime">—</span></div>
            <div style="margin-top:10px;display:flex;flex-direction:column;gap:5px">
                <button id="btnResetWaypoints" style="width:100%">Reset</button>
                <button id="btnClearWaypoints" style="width:100%">Clear All</button>
                <button id="btnExportWaypoints" style="width:100%">Export JSON</button>
                <button id="btnImportWaypoints" style="width:100%">Import JSON</button>
                <input type="file" id="waypointImportInput" accept=".json" style="display:none">
            </div>
            <div id="waypointSplits" style="margin-top:10px;max-height:200px;overflow-y:auto">
                <h5>Splits:</h5>
                <div id="waypointSplitsList" style="font-size:11px"></div>
            </div>
        </div>

        <!-- Script Editor panel (hidden until toggled) -->
        <div id="scriptEditorPanel" class="script-editor-panel" style="display:none">
            <h4>Movement Script Editor</h4>
            <textarea id="scriptTextArea" spellcheck="false" placeholder="// Movement script (125 FPS)
// Example:
+forward
wait 20
seta cl_yawspeed 200
+right
wait 4
-right
+moveup
wait 2
-moveup
wait 50
-forward"></textarea>
            <div style="display:flex;gap:8px;margin-top:8px">
                <button id="btnRunScript" class="btn-primary" style="flex:1">▶ Run</button>
                <button id="btnClearScript" style="flex:1">Clear</button>
                <button id="btnExportScript" style="flex:1">Export .cfg</button>
            </div>
            <div id="scriptStatus" style="margin-top:8px;font-size:12px;color:#aaa"></div>
        </div>

        <!-- Optimizer panel (hidden until toggled) -->
        <div id="optimizerPanel" class="optimizer-panel" style="display:none">
            <h4>Route Optimizer</h4>
            <div class="control-group">
                <label>Algorithm:</label>
                <select id="optimizerAlgo" style="width:100%">
                    <option value="de">Differential Evolution</option>
                    <option value="astar">A* Planner</option>
                </select>
            </div>
            <div class="control-group">
                <label>Max Frames: <input type="number" id="optimizerMaxFrames" value="250" min="10" max="2000" style="width:80px"></label>
            </div>
            <div class="control-group">
                <label>Target Jumps: <input type="number" id="optimizerTargetJumps" value="3" min="0" max="30" style="width:80px"></label>
            </div>
            <div class="control-group">
                <label>Generations/Evals: <input type="number" id="optimizerIters" value="60" min="5" max="500" style="width:80px"></label>
            </div>
            <button id="btnRunOptimizer" class="btn-primary" style="width:100%;margin-top:8px">⚡ Run Optimizer</button>
            <button id="btnCancelOptimizer" style="width:100%;margin-top:4px;display:none">Cancel</button>
            <div id="optimizerStatus" style="margin-top:8px;font-size:12px;color:#aaa"></div>
            <div id="optimizerProgress" style="margin-top:4px">
                <div id="optimizerProgressBar" style="height:4px;background:#333;border-radius:2px">
                    <div id="optimizerProgressFill" style="height:100%;width:0%;background:#4fc3f7;border-radius:2px;transition:width 0.2s"></div>
                </div>
            </div>
        </div>

        <!-- Legend -->
        <div class="legend" id="legendPanel">
            <h4>Legend</h4>
            <div class="legend-item"><div class="legend-color" style="background:#4fc3f7"></div><span>Path</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#ff6b6b"></div><span>Player</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#4caf50"></div><span>Velocity</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#ff9800"></div><span>Yaw</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#9c27b0"></div><span>Wish Dir</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#00ff00"></div><span>Spawns</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#ffff00"></div><span>Triggers</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#ff0000"></div><span>Waypoints</span></div>
        </div>
    </div>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/",
            "jszip": "https://cdn.skypack.dev/jszip@3.10.1"
        }
    }
    </script>

    <script type="module" src="../js/viewer3d-v2.js"></script>
</body>
</html>
