<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Q3 Movement 3D Viewer</title>
    <script src="https://unpkg.com/three@0.160.0/build/three.min.js"></script>
    <script src="https://unpkg.com/three@0.160.0/examples/js/controls/OrbitControls.js"></script>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: #1a1a1a;
            color: #fff;
            overflow: hidden;
        }
        .viewer-container {
            position: relative;
            width: 100vw;
            height: 100vh;
        }
        .controls-overlay {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 1000;
            background: rgba(42, 42, 42, 0.9);
            padding: 20px;
            border-radius: 8px;
            min-width: 300px;
            backdrop-filter: blur(10px);
        }
        button {
            padding: 8px 12px;
            background: #3a3a3a;
            color: #fff;
            border: 1px solid #555;
            border-radius: 4px;
            cursor: pointer;
        }
        button:hover {
            background: #4a4a4a;
        }
        .back-button {
            position: absolute;
            top: 20px;
            right: 20px;
            z-index: 1001;
        }
    </style>
</head>
<body>
    <div class="viewer-container">
        <div id="threejs-container"></div>
        <button class="back-button" onclick="window.history.back()">← Back to Charts</button>
        <div class="controls-overlay">
            <h3>3D Movement Viewer</h3>
            <p>Loading 3D visualization...</p>
        </div>
    </div>
    <script>console.log("3D Viewer loaded");</script>
</body>
</html>