using System.Text.RegularExpressions;
using Newtonsoft.Json;

namespace Q3BeamSearch.Services
{
    /// <summary>
    /// Service to parse Q3 CFG files and convert them to demo format for web simulation
    /// </summary>
    public class CfgParserService
    {
        /// <summary>
        /// Parse a movement.cfg file and convert to demo frames
        /// </summary>
        public List<FrameDto> ParseCfgToDemo(string cfgFilePath)
        {
            if (!File.Exists(cfgFilePath))
                throw new FileNotFoundException($"CFG file not found: {cfgFilePath}");

            var lines = File.ReadAllLines(cfgFilePath);
            var frames = new List<FrameDto>();
            
            // Parse the CFG and simulate the movement
            var inputs = ParseCfgToInputs(lines);
            
            // Simulate the movement to generate demo frames
            var ps = new PlayerState();
            for (int i = 0; i < inputs.Count; i++)
            {
                var input = inputs[i];
                Physics.Step(ps, input);
                
                double speedXY = Math.Sqrt(ps.Vel.X * ps.Vel.X + ps.Vel.Y * ps.Vel.Y);
                var frame = new FrameDto
                {
                    Frame = i,
                    X = ps.Pos.X,
                    Y = ps.Pos.Y,
                    Z = ps.Pos.Z,
                    Speed = speedXY,
                    OnGround = ps.OnGround,
                    YawDeg = ps.YawDeg
                };
                frames.Add(frame);
            }
            
            return frames;
        }

        /// <summary>
        /// Parse CFG commands to Input sequence
        /// </summary>
        private List<Input> ParseCfgToInputs(string[] lines)
        {
            var inputs = new List<Input>();
            var currentInput = new Input();
            
            // State tracking
            bool forwardHeld = false, backHeld = false;
            bool moveLeftHeld = false, moveRightHeld = false;
            bool leftTurnHeld = false, rightTurnHeld = false;
            double currentYawSpeed = 140.0; // Default Q3 yaw speed
            
            foreach (var line in lines)
            {
                var trimmed = line.Trim();
                if (string.IsNullOrEmpty(trimmed) || trimmed.StartsWith("//"))
                    continue;

                // Split commands separated by semicolons
                var commands = trimmed.Split(';', StringSplitOptions.RemoveEmptyEntries);
                
                foreach (var cmd in commands)
                {
                    var command = cmd.Trim();
                    
                    // Parse movement commands
                    if (command == "+forward")
                    {
                        forwardHeld = true;
                        currentInput.Fwd = 1;
                    }
                    else if (command == "-forward")
                    {
                        forwardHeld = false;
                        currentInput.Fwd = (sbyte)(backHeld ? -1 : 0);
                    }
                    else if (command == "+back")
                    {
                        backHeld = true;
                        currentInput.Fwd = -1;
                    }
                    else if (command == "-back")
                    {
                        backHeld = false;
                        currentInput.Fwd = (sbyte)(forwardHeld ? 1 : 0);
                    }
                    else if (command == "+moveleft")
                    {
                        moveLeftHeld = true;
                        currentInput.Str = -1;
                    }
                    else if (command == "-moveleft")
                    {
                        moveLeftHeld = false;
                        currentInput.Str = (sbyte)(moveRightHeld ? 1 : 0);
                    }
                    else if (command == "+moveright")
                    {
                        moveRightHeld = true;
                        currentInput.Str = 1;
                    }
                    else if (command == "-moveright")
                    {
                        moveRightHeld = false;
                        currentInput.Str = (sbyte)(moveLeftHeld ? -1 : 0);
                    }
                    else if (command == "+left")
                    {
                        leftTurnHeld = true;
                    }
                    else if (command == "-left")
                    {
                        leftTurnHeld = false;
                    }
                    else if (command == "+right")
                    {
                        rightTurnHeld = true;
                    }
                    else if (command == "-right")
                    {
                        rightTurnHeld = false;
                    }
                    else if (command == "+moveup")
                    {
                        currentInput.Jump = 1;
                    }
                    else if (command == "-moveup")
                    {
                        currentInput.Jump = 0;
                    }
                    else if (command.StartsWith("seta cl_yawspeed "))
                    {
                        var match = Regex.Match(command, @"seta cl_yawspeed\s+([\d.]+)");
                        if (match.Success && double.TryParse(match.Groups[1].Value, out double yawSpeed))
                        {
                            currentYawSpeed = yawSpeed;
                        }
                    }
                    else if (command.StartsWith("wait "))
                    {
                        var match = Regex.Match(command, @"wait\s+(\d+)");
                        if (match.Success && int.TryParse(match.Groups[1].Value, out int waitUnits))
                        {
                            // Each wait unit is 2 frames in the CFG (wait 2 = 1 frame)
                            int frames = waitUnits / 2;
                            
                            // Calculate yaw delta for this frame
                            double yawDelta = 0;
                            if (leftTurnHeld || rightTurnHeld)
                            {
                                // Convert yaw speed per second to yaw delta per frame
                                double yawPerFrame = currentYawSpeed / Q3.FPS;
                                yawDelta = leftTurnHeld ? yawPerFrame : -yawPerFrame;
                            }
                            currentInput.YawDeltaDeg = yawDelta;
                            
                            // Add frames for the wait period
                            for (int i = 0; i < frames; i++)
                            {
                                inputs.Add(new Input
                                {
                                    Fwd = currentInput.Fwd,
                                    Str = currentInput.Str,
                                    Jump = currentInput.Jump,
                                    YawDeltaDeg = currentInput.YawDeltaDeg
                                });
                            }
                        }
                    }
                }
            }
            
            return inputs;
        }

        /// <summary>
        /// Convert a CFG file to JSON demo format and save it
        /// </summary>
        public async Task ConvertCfgToJsonDemo(string cfgPath, string outputPath)
        {
            var frames = ParseCfgToDemo(cfgPath);
            var json = JsonConvert.SerializeObject(frames, Formatting.None);
            await File.WriteAllTextAsync(outputPath, json);
        }
    }
}