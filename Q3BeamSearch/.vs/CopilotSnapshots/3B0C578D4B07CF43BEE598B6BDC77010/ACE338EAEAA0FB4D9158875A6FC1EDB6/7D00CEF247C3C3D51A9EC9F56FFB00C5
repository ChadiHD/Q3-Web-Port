using System.Collections.Generic;
using System.IO;

namespace Q3BeamSearch.Export
{
    public static class Q3CfgExporter
    {
        // Export cfg with jump pulses when simulated state indicates the player is on ground.
        // Uses 125 FPS timing (pmove_fixed 1, pmove_msec 8) and compresses consecutive waits.
        public static void Export(List<Q3BeamSearch.Input> inputs, string filename, int maxJumps, int airFrames48)
        {
            // Export to current directory
            ExportToPath(inputs, filename, maxJumps, airFrames48);
            
            // Also export to web app demos folder if it exists
            var webDemosDir = Path.Combine("..", "..", "wwwroot", "demos");
            if (Directory.Exists(webDemosDir))
            {
                var webFilename = Path.Combine(webDemosDir, Path.GetFileName(filename));
                ExportToPath(inputs, webFilename, maxJumps, airFrames48);
                Console.WriteLine($"Also exported to web demos folder: {webFilename}");
            }
        }
        
        private static void ExportToPath(List<Q3BeamSearch.Input> inputs, string filename, int maxJumps, int airFrames48)
        {
            // Ensure directory exists
            var directory = Path.GetDirectoryName(filename);
            if (!string.IsNullOrEmpty(directory) && !Directory.Exists(directory))
            {
                Directory.CreateDirectory(directory);
            }
            
            using var writer = new StreamWriter(filename);

            writer.WriteLine("// Auto-generated by Q3 Optimizer (auto-jump using simulated ps.OnGround)");
            writer.WriteLine($"// FPS {Q3BeamSearch.Q3.FPS}, frames {inputs.Count}");
            writer.WriteLine("// Controls used: +forward/+back, +moveleft/+moveright, +left/+right, +moveup, wait N, cl_yawspeed");
            writer.WriteLine("// Engine timing for consistency");
            writer.WriteLine("seta pmove_fixed 1");
            writer.WriteLine("seta pmove_msec 8");
            writer.WriteLine();

            bool leftHeld = false, rightHeld = false;
            bool forwardHeld = false, backHeld = false, moveLeftHeld = false, moveRightHeld = false;
            int jumpsDone = 0;
            double lastYawSpeed = double.NaN; // track cl_yawspeed to avoid redundant sets

            // Simulated state to know when the player is on ground at each frame start
            var sim = new Q3BeamSearch.PlayerState();

            // Ensure exporter simulation doesn't auto-bhop; we only emit jumps when OnGround
            bool prevAutoBhop = Q3BeamSearch.Physics.AutoBHop;
            Q3BeamSearch.Physics.AutoBHop = false;

            // Aggregate waits (each unit equals 1 frame => wait 2)
            int pendingWaitUnits = 0;

            void FlushPendingWaits()
            {
                if (pendingWaitUnits > 0)
                {
                    writer.WriteLine($"wait {pendingWaitUnits * 2}");
                    pendingWaitUnits = 0;
                }
            }

            try
            {
                for (int i = 0; i < inputs.Count; i++)
                {
                    var toggles = new List<string>(); // movement toggles
                    var openPulse = new List<string>(); // +left/+right/+moveup for this frame only
                    var closePulse = new List<string>(); // -left/-right/-moveup for this frame only
                    var inp = inputs[i];

                    // Movement keys (press/release only on changes)
                    if (inp.Fwd > 0 && !forwardHeld) { toggles.Add("+forward"); forwardHeld = true; }
                    if (inp.Fwd <= 0 && forwardHeld) { toggles.Add("-forward"); forwardHeld = false; }
                    if (inp.Fwd < 0 && !backHeld) { toggles.Add("+back"); backHeld = true; }
                    if (inp.Fwd >= 0 && backHeld) { toggles.Add("-back"); backHeld = false; }

                    if (inp.Str > 0 && !moveRightHeld) { toggles.Add("+moveright"); moveRightHeld = true; }
                    if (inp.Str <= 0 && moveRightHeld) { toggles.Add("-moveright"); moveRightHeld = false; }
                    if (inp.Str < 0 && !moveLeftHeld) { toggles.Add("+moveleft"); moveLeftHeld = true; }
                    if (inp.Str >= 0 && moveLeftHeld) { toggles.Add("-moveleft"); moveLeftHeld = false; }

                    // Turning per frame based on YawDeltaDeg (frame-local pulse)
                    double absYaw = System.Math.Abs(inp.YawDeltaDeg);
                    if (absYaw > 1e-6)
                    {
                        double yawSpeedPerSec = absYaw * Q3BeamSearch.Q3.FPS;
                        if (double.IsNaN(lastYawSpeed) || System.Math.Abs(yawSpeedPerSec - lastYawSpeed) > 1e-6)
                        {
                            toggles.Add($"seta cl_yawspeed {yawSpeedPerSec:0.###}");
                            lastYawSpeed = yawSpeedPerSec;
                        }
                        if (inp.YawDeltaDeg > 0)
                        {
                            // Ensure opposite is not held
                            if (rightHeld) { toggles.Add("-right"); rightHeld = false; }
                            openPulse.Add("+left");
                            closePulse.Add("-left");
                        }
                        else
                        {
                            if (leftHeld) { toggles.Add("-left"); leftHeld = false; }
                            openPulse.Add("+right");
                            closePulse.Add("-right");
                        }
                    }
                    else
                    {
                        // Ensure no yaw is held across frames
                        if (leftHeld) { toggles.Add("-left"); leftHeld = false; }
                        if (rightHeld) { toggles.Add("-right"); rightHeld = false; }
                    }

                    // Decide jump this frame based on simulated OnGround at frame start (frame-local pulse)
                    bool willJump = sim.OnGround && jumpsDone < maxJumps;
                    if (willJump)
                    {
                        openPulse.Add("+moveup");
                        closePulse.Add("-moveup");
                    }

                    // Emit commands for this frame
                    if (toggles.Count > 0 || openPulse.Count > 0)
                    {
                        // Ensure timeline respects prior idle frames
                        FlushPendingWaits();

                        var line = new List<string>();
                        line.AddRange(toggles);
                        line.AddRange(openPulse);
                        line.Add("wait 2");
                        line.AddRange(closePulse);
                        writer.WriteLine(string.Join(";", line));
                    }
                    else
                    {
                        // No state changes this frame: accumulate waits
                        pendingWaitUnits += 1;
                    }

                    if (willJump)
                    {
                        jumpsDone++;
                    }

                    // Advance simulated state using same inputs and jump decision
                    var simInput = new Q3BeamSearch.Input
                    {
                        Fwd = inp.Fwd,
                        Str = inp.Str,
                        Jump = (byte)(willJump ? 1 : 0),
                        YawDeltaDeg = inp.YawDeltaDeg
                    };
                    Q3BeamSearch.Physics.Step(sim, simInput);
                }
            }
            finally
            {
                Q3BeamSearch.Physics.AutoBHop = prevAutoBhop;
            }

            // Flush any trailing waits
            if (pendingWaitUnits > 0)
            {
                writer.WriteLine($"wait {pendingWaitUnits * 2}");
            }

            // Release held keys at end
            var tail = new List<string>();
            if (leftHeld) tail.Add("-left");
            if (rightHeld) tail.Add("-right");
            if (forwardHeld) tail.Add("-forward");
            if (backHeld) tail.Add("-back");
            if (moveRightHeld) tail.Add("-moveright");
            if (moveLeftHeld) tail.Add("-moveleft");
            if (tail.Count > 0) writer.WriteLine(string.Join(";", tail));
        }
    }
}