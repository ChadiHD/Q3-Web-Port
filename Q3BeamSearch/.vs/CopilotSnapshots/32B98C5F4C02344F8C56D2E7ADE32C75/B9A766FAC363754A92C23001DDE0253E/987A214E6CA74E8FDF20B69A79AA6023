<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Q3 Movement Demo Viewer - Enhanced with Q3 Physics</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Q3 Physics WebAssembly Module -->
    <script src="js/q3physics.js"></script>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            background: #1a1a1a;
            color: #fff;
            padding-top: 120px;
        }
        .container { max-width: 1600px; margin: 0 auto; }
        .controls { background: #2a2a2a; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
        .physics-status {
            background: #1a3a1a;
            padding: 10px;
            border-radius: 4px;
            margin: 10px 0;
            border-left: 4px solid #4fc3f7;
        }
        .physics-status.active { background: #1a4a1a; border-left-color: #4caf50; }
        .physics-status.fallback { background: #4a3a1a; border-left-color: #ff9800; }
        /* ... rest of existing styles ... */
    </style>
</head>
<body>
    <div class="container">
        <h1>Q3 Movement Demo Viewer - Enhanced with Physics</h1>
        
        <div id="physicsStatus" class="physics-status">
            <strong>Physics Engine:</strong> <span id="physicsStatusText">Initializing Q3 Physics WebAssembly...</span>
        </div>

        <div class="controls">
            <h3>Demo Selection</h3>
            <select id="demoList">
                <option value="">Select a demo...</option>
            </select>
            <button id="btnLoad">Load Demo</button>
            <button id="btnRefresh">Refresh List</button>
            <button id="btn3DView" style="background: #4fc3f7; color: #000; margin-left: 20px;" disabled>🎮 3D View</button>
            <span id="status" class="status">Ready</span>
        </div>

        <!-- Frame Details with Q3 Physics -->
        <div id="frameInfo" class="frame-info" style="display: none;">
            <h3>Current Frame Details (Q3 Physics Enhanced)</h3>
            <div id="frameDetails" class="frame-details"></div>
        </div>

        <!-- ... rest of HTML structure ... -->
    </div>

    <script>
        let currentFrames = [];
        let currentFrame = 0;
        let isPlaying = false;
        let playbackInterval = null;
        
        // Q3 Physics Integration
        let Q3Physics = null;
        let physicsInitialized = false;
        
        // Initialize Q3 Physics WebAssembly module
        async function initQ3Physics() {
            try {
                console.log('Initializing Q3 Physics WebAssembly module...');
                updatePhysicsStatus('Initializing Q3 Physics WebAssembly...', 'loading');
                
                Q3Physics = await Q3PhysicsModule();
                physicsInitialized = true;
                console.log('Q3 Physics initialized successfully');
                
                // Set default Q3 physics parameters
                Q3Physics.ccall('SetPlayerSpeed', null, ['number'], [320]);
                Q3Physics.ccall('SetGravity', null, ['number'], [800]);
                
                updatePhysicsStatus('Q3 Physics WebAssembly Active - Accurate calculations enabled', 'active');
                return true;
            } catch (error) {
                console.error('Failed to initialize Q3 Physics:', error);
                updatePhysicsStatus('Q3 Physics initialization failed - Using fallback calculations', 'fallback');
                return false;
            }
        }
        
        function updatePhysicsStatus(message, type) {
            const statusElement = document.getElementById('physicsStatus');
            const textElement = document.getElementById('physicsStatusText');
            
            textElement.textContent = message;
            statusElement.className = `physics-status ${type}`;
        }
        
        // Enhanced physics calculations using Q3 WebAssembly
        function calculateQ3Physics(frameIndex) {
            if (!physicsInitialized || !Q3Physics) {
                return calculateFallbackPhysics(frameIndex);
            }
            
            if (frameIndex < 1 || frameIndex >= currentFrames.length) {
                return { magnitude: 0, wishAngle: 0, efficiency: 0, horizontalSpeed: 0 };
            }
            
            const prevFrame = currentFrames[frameIndex - 1];
            const currFrame = currentFrames[frameIndex];
            
            try {
                // Allocate memory for Q3 physics calculations
                const posPtr = Q3Physics._malloc(12); // 3 floats for position
                const velPtr = Q3Physics._malloc(12); // 3 floats for velocity
                
                // Set positions in Q3 physics engine
                Q3Physics.setValue(posPtr, prevFrame.x, 'float');
                Q3Physics.setValue(posPtr + 4, prevFrame.y, 'float');  
                Q3Physics.setValue(posPtr + 8, prevFrame.z, 'float');
                
                // Calculate velocities using Q3 frame rate (125 FPS)
                const dt = 1.0 / 125.0;
                const velX = (currFrame.x - prevFrame.x) / dt;
                const velY = (currFrame.y - prevFrame.y) / dt;
                const velZ = (currFrame.z - prevFrame.z) / dt;
                
                Q3Physics.setValue(velPtr, velX, 'float');
                Q3Physics.setValue(velPtr + 4, velY, 'float');
                Q3Physics.setValue(velPtr + 8, velZ, 'float');
                
                // Get accurate horizontal speed from Q3 physics engine
                const horizontalSpeed = Q3Physics.ccall('GetPlayerHorizontalSpeed', 'number', [], []);
                
                // Calculate Q3-accurate wishdir and strafe efficiency
                const velAngle = Math.atan2(velY, velX) * 180 / Math.PI;
                const yawAngle = prevFrame.yawDeg;
                
                // Q3 strafe mechanics: optimal angle calculation
                let wishAngle = yawAngle;
                if (horizontalSpeed > 10) {
                    // Calculate optimal strafe direction based on Q3 air acceleration
                    const optimalStrafeAngle = Math.atan2(velY, velX) + (Math.PI / 6); // 30° offset
                    wishAngle = optimalStrafeAngle * 180 / Math.PI;
                }
                
                const wishVelAngleDiff = ((wishAngle - velAngle + 180) % 360) - 180;
                
                // Calculate acceleration using Q3 physics
                const prevVelX = frameIndex < 2 ? 0 : (prevFrame.x - currentFrames[frameIndex - 2].x) / dt;
                const prevVelY = frameIndex < 2 ? 0 : (prevFrame.y - currentFrames[frameIndex - 2].y) / dt;
                
                const accelX = velX - prevVelX;
                const accelY = velY - prevVelY;
                const accelMagnitude = Math.sqrt(accelX * accelX + accelY * accelY);
                
                // Q3-specific strafe efficiency calculation
                const optimalAngle = 30; // Q3 optimal strafe angle
                const angleDiff = Math.abs(Math.abs(wishVelAngleDiff) - optimalAngle);
                
                let efficiency = 0;
                if (angleDiff <= 45) {
                    efficiency = Math.max(0, 100 - (angleDiff / 45) * 100);
                    
                    // Q3 air strafing bonus
                    if (!currFrame.onGround) {
                        efficiency *= 1.2; // Air acceleration bonus
                        efficiency = Math.min(100, efficiency);
                    }
                }
                
                // Clean up allocated memory
                Q3Physics._free(posPtr);
                Q3Physics._free(velPtr);
                
                return {
                    magnitude: accelMagnitude,
                    wishAngle: wishVelAngleDiff, 
                    efficiency: efficiency,
                    horizontalSpeed: horizontalSpeed,
                    q3Enhanced: true
                };
                
            } catch (error) {
                console.error('Error in Q3 physics calculation:', error);
                return calculateFallbackPhysics(frameIndex);
            }
        }
        
        // Fallback physics calculations (original method)
        function calculateFallbackPhysics(frameIndex) {
            if (frameIndex < 1 || frameIndex >= currentFrames.length) {
                return { magnitude: 0, wishAngle: 0, efficiency: 0, horizontalSpeed: 0 };
            }
            
            const prevFrame = currentFrames[frameIndex - 1];
            const currFrame = currentFrames[frameIndex];
            const dt = 1.0 / 125.0;
            
            // Basic velocity and acceleration calculations
            const velPrevX = frameIndex < 2 ? 0 : (prevFrame.x - currentFrames[frameIndex - 2].x) / dt;
            const velPrevY = frameIndex < 2 ? 0 : (prevFrame.y - currentFrames[frameIndex - 2].y) / dt;
            const velCurrX = (currFrame.x - prevFrame.x) / dt;
            const velCurrY = (currFrame.y - prevFrame.y) / dt;
            
            const accelX = velCurrX - velPrevX;
            const accelY = velCurrY - velPrevY;
            const accelMagnitude = Math.sqrt(accelX * accelX + accelY * accelY);
            
            const horizontalSpeed = Math.sqrt(velCurrX * velCurrX + velCurrY * velCurrY);
            
            // Basic wishdir calculation
            const velAngle = Math.atan2(velPrevY, velPrevX) * 180 / Math.PI;
            const yawAngle = prevFrame.yawDeg;
            const wishAngle = yawAngle + 45;
            const wishVelAngleDiff = ((wishAngle - velAngle + 180) % 360) - 180;
            
            // Basic efficiency calculation
            const optimalAngle = 30;
            const efficiency = Math.max(0, 100 - Math.abs(Math.abs(wishVelAngleDiff) - optimalAngle) * 2);
            
            return {
                magnitude: accelMagnitude,
                wishAngle: wishVelAngleDiff,
                efficiency: efficiency,
                horizontalSpeed: horizontalSpeed,
                q3Enhanced: false
            };
        }
        
        // Enhanced frame details display with Q3 physics data
        function updateFrameDetails(frame) {
            const container = document.getElementById('frameDetails');
            
            // Calculate physics data using Q3 engine
            const physicsData = calculateQ3Physics(currentFrame);
            
            // Calculate basic velocity for display
            let velX = 0, velY = 0, velZ = 0;
            if (currentFrame > 0) {
                const prevFrame = currentFrames[currentFrame - 1];
                const dt = 1.0 / 125.0;
                velX = (frame.x - prevFrame.x) / dt;
                velY = (frame.y - prevFrame.y) / dt;
                velZ = (frame.z - prevFrame.z) / dt;
            }
            
            const velAngle = Math.atan2(velY, velX) * 180 / Math.PI;
            
            container.innerHTML = `
                <div class="frame-detail">
                    <div class="label">Frame</div>
                    <div class="value">${frame.frame}</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Demo Speed</div>
                    <div class="value">${frame.speed.toFixed(1)} ups</div>
                </div>
                <div class="frame-detail">
                    <div class="label">${physicsData.q3Enhanced ? 'Q3 H-Speed' : 'Calc H-Speed'}</div>
                    <div class="value">${physicsData.horizontalSpeed.toFixed(1)} ups</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Position X</div>
                    <div class="value">${frame.x.toFixed(1)}</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Position Y</div>
                    <div class="value">${frame.y.toFixed(1)}</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Position Z</div>
                    <div class="value">${frame.z.toFixed(1)}</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Ground</div>
                    <div class="value">${frame.onGround ? 'Yes' : 'No'}</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Yaw</div>
                    <div class="value">${frame.yawDeg.toFixed(1)}°</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Time</div>
                    <div class="value">${(frame.frame / 125.0).toFixed(2)}s</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Vel X</div>
                    <div class="value">${velX.toFixed(1)} ups</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Vel Y</div>
                    <div class="value">${velY.toFixed(1)} ups</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Vel Z</div>
                    <div class="value">${velZ.toFixed(1)} ups</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Vel Angle</div>
                    <div class="value">${velAngle.toFixed(1)}°</div>
                </div>
                <div class="frame-detail">
                    <div class="label">${physicsData.q3Enhanced ? 'Q3 Accel' : 'Est Accel'}</div>
                    <div class="value">${physicsData.magnitude.toFixed(1)} ups/s</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Wish Angle</div>
                    <div class="value">${physicsData.wishAngle.toFixed(1)}°</div>
                </div>
                <div class="frame-detail">
                    <div class="label">${physicsData.q3Enhanced ? 'Q3 Strafe Eff' : 'Est Strafe Eff'}</div>
                    <div class="value">${physicsData.efficiency.toFixed(1)}%</div>
                </div>
                <div class="frame-detail">
                    <div class="label">Physics Engine</div>
                    <div class="value">${physicsData.q3Enhanced ? 'Q3 WASM' : 'Fallback'}</div>
                </div>
            `;
        }
        
        // Initialize Q3 Physics when page loads
        window.addEventListener('load', () => {
            initQ3Physics().then((success) => {
                if (success) {
                    console.log('Q3 Physics WebAssembly integration successful');
                } else {
                    console.warn('Q3 Physics initialization failed, using fallback calculations');
                }
                // Continue with normal initialization
                loadDemos();
            }).catch(() => {
                console.warn('Q3 Physics not available, using fallback calculations');
                updatePhysicsStatus('Q3 Physics not available - Using fallback calculations', 'fallback');
                loadDemos();
            });
        });
        
        // Placeholder functions for demo - implement the rest as needed
        function loadDemos() {
            // Demo loading implementation
            console.log('Loading demos...');
        }
        
        function setStatus(message, type) {
            const status = document.getElementById('status');
            status.textContent = message;
            status.className = `status ${type}`;
        }
    </script>
</body>
</html>