// Animation loop
function animate() {
    requestAnimationFrame(animate);

    const delta = clock.getDelta();
    if (controls) controls.update(delta);

    // Update physics and frames
    if (Q3Physics && physicsInitialized) {
        // Step the physics simulation
        Q3Physics.ccall('Step', null, ['number'], [1 / 60]);

        // Update frames data
        currentFrames = Q3Physics.getCurrentFrames();
    }

    // Update player and visualization based on current frame
    if (currentFrames.length > 0) {
        const frame = currentFrames[currentFrame];

        // Update player position and rotation
        if (playerSphere) {
            playerSphere.position.set(frame.x, frame.y, frame.z);
            playerSphere.rotation.set(0, frame.yawDeg * Math.PI / 180, 0);
        }

        // Update path and trail
        updatePathVisualization(frame);
    }

    renderer.render(scene, camera);
}

// Update path visualization based on the current frame
function updatePathVisualization(frame) {
    if (!pathLine || !currentMapData) return;

    const entity = currentMapData.entities.find(e => e.properties.classname?.includes('path'));
    if (!entity) return;

    const points = [];
    for (let i = 0; i <= currentFrame; i++) {
        const f = currentFrames[i];
        points.push(new THREE.Vector3(f.x, f.y, f.z));
    }

    const pathGeometry = new THREE.BufferGeometry().setFromPoints(points);
    pathLine.geometry.dispose();
    pathLine.geometry = pathGeometry;
}

// Load and display a map from the selected file
async function loadMap(file) {
    const loader = new EnhancedMapLoader();
    try {
        // Load map data from file
        currentMapData = await loader.loadMapFromFile(file);

        // Add map objects to the scene
        loader.addMapObjectsToScene(currentMapData, { withPlayer: true, withPath: true });

        // Display entity and texture information
        const categories = loader.categorizeEntities(currentMapData.entities);
        displayEntityInfo(categories);

        console.log('Map loaded successfully:', currentMapData);
    } catch (error) {
        console.error('Error loading map:', error);
    }
}

