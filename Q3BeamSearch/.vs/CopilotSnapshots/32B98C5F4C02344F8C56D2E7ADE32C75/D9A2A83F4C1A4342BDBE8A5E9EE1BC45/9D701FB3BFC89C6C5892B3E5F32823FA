// Initialize Q3 Physics WebAssembly module
async function initQ3Physics() {
    try {
        console.log('[3D Viewer] Initializing Q3 Physics WebAssembly module...');
        Q3Physics = await Q3PhysicsModule();
        physicsInitialized = true;
        console.log('[3D Viewer] Q3 Physics initialized successfully');
        
        // Set default Q3 physics parameters
        Q3Physics.ccall('SetPlayerSpeed', null, ['number'], [320]);
        Q3Physics.ccall('SetGravity', null, ['number'], [800]);
        
        return true;
    } catch (error) {
        console.error('[3D Viewer] Failed to initialize Q3 Physics:', error);
        return false;
    }
}

// Enhanced physics calculations using Q3 WebAssembly
function calculateQ3Physics(frameIndex) {
    if (!physicsInitialized || !Q3Physics || frameIndex < 1 || frameIndex >= currentFrames.length) {
        return calculateFallbackPhysics(frameIndex);
    }
    
    const prevFrame = currentFrames[frameIndex - 1];
    const currFrame = currentFrames[frameIndex];
    
    try {
        const dt = 1.0 / 125.0;
        const velX = (currFrame.x - prevFrame.x) / dt;
        const velY = (currFrame.y - prevFrame.y) / dt;
        
        const horizontalSpeed = Math.sqrt(velX * velX + velY * velY);
        const velocityAngle = Math.atan2(velY, velX);
        const yawAngle = prevFrame.yawDeg * Math.PI / 180;
        
        let optimalWishAngle = yawAngle;
        if (horizontalSpeed > 10) {
            optimalWishAngle = velocityAngle + (Math.PI / 6);
        }
        
        const prevVelX = frameIndex < 2 ? 0 : (prevFrame.x - currentFrames[frameIndex - 2].x) / dt;
        const prevVelY = frameIndex < 2 ? 0 : (prevFrame.y - currentFrames[frameIndex - 2].y) / dt;
        const accelX = velX - prevVelX;
        const accelY = velY - prevVelY;
        const accelMagnitude = Math.sqrt(accelX * accelX + accelY * accelY);
        
        const wishAngleDeg = optimalWishAngle * 180 / Math.PI;
        const velAngleDeg = velocityAngle * 180 / Math.PI;
        const angleDiff = Math.abs(((wishAngleDeg - velAngleDeg + 180) % 360) - 180);
        const optimalAngle = 30;
        
        let efficiency = 0;
        if (angleDiff <= 45) {
            efficiency = Math.max(0, 100 - (Math.abs(angleDiff - optimalAngle) / 45) * 100);
            if (!currFrame.onGround) {
                efficiency *= 1.2;
                efficiency = Math.min(100, efficiency);
            }
        }
        
        return {
            horizontalSpeed,
            velocityAngle,
            optimalWishAngle,
            efficiency,
            acceleration: accelMagnitude,
            q3Enhanced: true
        };
    } catch (error) {
        console.error('[3D Viewer] Error in Q3 physics:', error);
        return calculateFallbackPhysics(frameIndex);
    }
}

// Fallback physics calculations
function calculateFallbackPhysics(frameIndex) {
    if (frameIndex < 1 || frameIndex >= currentFrames.length) {
        return { 
            horizontalSpeed: 0, velocityAngle: 0, optimalWishAngle: 0,
            efficiency: 0, acceleration: 0, q3Enhanced: false
        };
    }
    
    const prevFrame = currentFrames[frameIndex - 1];
    const currFrame = currentFrames[frameIndex];
    const dt = 1.0 / 125.0;
    const velX = (currFrame.x - prevFrame.x) / dt;
    const velY = (currFrame.y - prevFrame.y) / dt;
    const horizontalSpeed = Math.sqrt(velX * velX + velY * velY);
    const velocityAngle = Math.atan2(velY, velX);
    const optimalWishAngle = velocityAngle + (Math.PI / 6);
    
    return {
        horizontalSpeed, velocityAngle, optimalWishAngle,
        efficiency: 50, acceleration: 0, q3Enhanced: false
    };
}

// Enhanced BSP/PK3 Map Loader Class
class EnhancedMapLoader {
    constructor() {
        this.mapData = null;
        this.textures = new Map();
        this.materials = new Map();
    }

    // Load PK3 or BSP from file
    async loadMapFromFile(file) {
        const fileName = file.name.toLowerCase();

        if (fileName.endsWith('.pk3')) {
            return this.loadPK3FromFile(file);
        } else if (fileName.endsWith('.bsp')) {
            return this.loadBSPFromFile(file);
        } else {
            throw new Error('Unsupported file format. Please select a .bsp or .pk3 file.');
        }
    }

    // Load PK3 file (ZIP archive)
    async loadPK3FromFile(file) {
        console.log('Loading PK3 file:', file.name);

        try {
            const zip = await JSZip.loadAsync(file);
            console.log('PK3 loaded, extracting contents...');

            // Find BSP file in maps/ directory
            let bspFile = null;

            zip.forEach((relativePath, zipEntry) => {
                if (relativePath.startsWith('maps/') && relativePath.endsWith('.bsp')) {
                    bspFile = zipEntry;
                }
            });

            if (!bspFile) {
                throw new Error('No BSP file found in maps/ directory');
            }

            console.log('Found BSP file:', bspFile.name);
            const bspArrayBuffer = await bspFile.async('arraybuffer');
            const bspData = this.parseBSP(bspArrayBuffer);

            // Load textures
            const textures = await this.loadTexturesFromPK3(zip);

            // Load shaders (if present)
            const shaders = await this.loadShadersFromPK3(zip);

            return {
                type: 'pk3',
                bsp: bspData,
                textures: textures,
                shaders: shaders,
                zipFile: zip
            };

        } catch (error) {
            console.error('Failed to load PK3:', error);
            throw error;
        }
    }

    // Load textures from PK3
    async loadTexturesFromPK3(zip) {
        const textures = new Map();
        const texturePromises = [];

        zip.forEach((relativePath, zipEntry) => {
            if (relativePath.startsWith('textures/') &&
                (relativePath.endsWith('.jpg') ||
                    relativePath.endsWith('.tga') ||
                    relativePath.endsWith('.png'))) {

                const textureName = relativePath.split('/').pop().split('.')[0];

                const promise = zipEntry.async('blob').then(blob => {
                    return new Promise((resolve) => {
                        const img = new Image();
                        img.onload = () => {
                            const texture = new THREE.Texture(img);
                            texture.needsUpdate = true;
                            texture.wrapS = THREE.RepeatWrapping;
                            texture.wrapT = THREE.RepeatWrapping;
                            textures.set(textureName.toLowerCase(), texture);
                            console.log('Loaded texture:', textureName);
                            resolve();
                        };
                        img.src = URL.createObjectURL(blob);
                    });
                }).catch(error => {
                    console.warn('Failed to load texture:', relativePath, error);
                });

                texturePromises.push(promise);
            }
        });

        await Promise.all(texturePromises);
        console.log(`Loaded ${textures.size} textures`);
        return textures;
    }

    // Load shader scripts from PK3
    async loadShadersFromPK3(zip) {
        const shaders = new Map();

        zip.forEach(async (relativePath, zipEntry) => {
            if (relativePath.startsWith('scripts/') && relativePath.endsWith('.shader')) {
                try {
                    const shaderText = await zipEntry.async('text');
                    this.parseShaderScript(shaderText, shaders);
                } catch (error) {
                    console.warn('Failed to load shader:', relativePath, error);
                }
            }
        });

        return shaders;
    }

    // Parse Quake 3 shader script
    parseShaderScript(shaderText, shaders) {
        const lines = shaderText.split('\n');
        let currentShader = null;

        for (let line of lines) {
            line = line.trim();
            if (line.startsWith('//') || line === '') continue;

            if (line.includes('{')) {
                const shaderName = line.replace('{', '').trim();
                currentShader = {
                    name: shaderName,
                    stages: [],
                    properties: {}
                };
            } else if (line.includes('}') && currentShader) {
                shaders.set(currentShader.name.toLowerCase(), currentShader);
                currentShader = null;
            } else if (currentShader && line.includes('map')) {
                const mapPath = line.replace('map', '').trim();
                currentShader.stages.push({ map: mapPath });
            }
        }
    }

    // Load BSP from file
    async loadBSPFromFile(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const bspData = this.parseBSP(e.target.result);
                    resolve({
                        type: 'bsp',
                        bsp: bspData,
                        textures: new Map(),
                        shaders: new Map()
                    });
                } catch (error) {
                    reject(error);
                }
            };
            reader.onerror = () => reject(new Error('Failed to read file'));
            reader.readAsArrayBuffer(file);
        });
    }

    // Parse BSP file format
    parseBSP(arrayBuffer) {
        const dataView = new DataView(arrayBuffer);
        let offset = 0;

        // Read BSP header
        const magic = dataView.getUint32(offset, true); offset += 4;
        const version = dataView.getUint32(offset, true); offset += 4;

        if (magic !== 0x50534249) { // "IBSP"
            throw new Error('Invalid BSP file format');
        }

        console.log(`BSP Version: ${version}`);

        // Read directory entries (17 lumps for Q3 BSP)
        const lumps = [];
        for (let i = 0; i < 17; i++) {
            lumps.push({
                offset: dataView.getUint32(offset, true),
                length: dataView.getUint32(offset + 4, true)
            });
            offset += 8;
        }

        // Parse essential lumps
        const vertices = this.parseVertices(arrayBuffer, lumps[10]);
        const faces = this.parseFaces(arrayBuffer, lumps[13]);
        const meshVerts = this.parseMeshVerts(arrayBuffer, lumps[11]);
        const textures = this.parseTextures(arrayBuffer, lumps[1]);

        // Parse entities from lump 0 (LUMP_ENTITIES)
        const entities = this.parseEntities(arrayBuffer, lumps[0]);

        console.log(`Loaded: ${vertices.length} vertices, ${faces.length} faces, ${textures.length} textures, ${entities.length} entities`);

        return {
            vertices,
            faces,
            meshVerts,
            textures,
            entities,
            lumps
        };
    }

    // Parse entities from BSP (Lump 0)
    parseEntities(arrayBuffer, lump) {
        const entities = [];

        if (lump.length === 0) {
            console.warn('No entity data found in BSP');
            return entities;
        }

        // Entity data is stored as a null-terminated string
        const entityString = new TextDecoder('utf-8').decode(
            new Uint8Array(arrayBuffer, lump.offset, lump.length)
        );

        console.log('Entity string length:', entityString.length);

        // Parse entity string format
        const lines = entityString.split('\n');
        let currentEntity = null;
        let braceCount = 0;

        for (let line of lines) {
            line = line.trim();
            if (line === '' || line.startsWith('//')) continue;

            if (line === '{') {
                braceCount++;
                if (braceCount === 1) {
                    currentEntity = { properties: {} };
                }
            } else if (line === '}') {
                braceCount--;
                if (braceCount === 0 && currentEntity) {
                    entities.push(currentEntity);
                    currentEntity = null;
                }
            } else if (currentEntity && braceCount === 1) {
                // Parse property line: "key" "value"
                const match = line.match(/^"([^"]+)"\s+"([^"]*)"$/);
                if (match) {
                    const [, key, value] = match;
                    currentEntity.properties[key] = value;
                }
            }
        }

        console.log(`Parsed ${entities.length} entities`);
        const categories = this.categorizeEntities(entities);
        return entities;
    }

    // Categorize entities by type
    categorizeEntities(entities) {
        const categories = {
            players: [],
            triggers: [],
            items: [],
            lights: [],
            other: []
        };

        entities.forEach((entity, index) => {
            const classname = entity.properties.classname || '';
            entity.index = index;

            if (classname.includes('info_player') || classname.includes('info_spectator')) {
                categories.players.push(entity);
            } else if (classname.startsWith('trigger_')) {
                categories.triggers.push(entity);
            } else if (classname.startsWith('item_') || classname.startsWith('weapon_') || classname.startsWith('ammo_')) {
                categories.items.push(entity);
            } else if (classname.includes('light')) {
                categories.lights.push(entity);
            } else {
                categories.other.push(entity);
            }
        });

        console.log('Entity categories:', {
            players: categories.players.length,
            triggers: categories.triggers.length,
            items: categories.items.length,
            lights: categories.lights.length,
            other: categories.other.length
        });

        // Update UI
        document.getElementById('entityCount').innerHTML = `
                    <div>Players: ${categories.players.length}</div>
                    <div>Triggers: ${categories.triggers.length}</div>
                    <div>Items: ${categories.items.length}</div>
                    <div>Lights: ${categories.lights.length}</div>
                    <div>Other: ${categories.other.length}</div>
                `;

        return categories;
    }

    // Parse origin string "x y z" to array [x, y, z]
    parseOrigin(originString) {
        if (!originString) return [0, 0, 0];
        const coords = originString.split(' ').map(parseFloat);
        return coords.length >= 3 ? coords : [0, 0, 0];
    }

    // Parse angle to radians (Q3 uses degrees)
    parseAngle(angleString) {
        if (!angleString) return 0;
        return parseFloat(angleString) * Math.PI / 180;
    }

    // Parse texture lump from BSP
    parseTextures(arrayBuffer, lump) {
        const textures = [];
        const dataView = new DataView(arrayBuffer, lump.offset, lump.length);
        const textureSize = 72;
        const numTextures = lump.length / textureSize;

        for (let i = 0; i < numTextures; i++) {
            const offset = i * textureSize;
            const nameBytes = new Uint8Array(arrayBuffer, lump.offset + offset, 64);

            let name = '';
            for (let j = 0; j < 64 && nameBytes[j] !== 0; j++) {
                name += String.fromCharCode(nameBytes[j]);
            }

            textures.push({
                name: name,
                flags: dataView.getUint32(offset + 64, true),
                contents: dataView.getUint32(offset + 68, true)
            });
        }

        return textures;
    }

    parseVertices(arrayBuffer, lump) {
        const vertices = [];
        const dataView = new DataView(arrayBuffer, lump.offset, lump.length);
        const vertexSize = 44;
        const numVertices = lump.length / vertexSize;

        for (let i = 0; i < numVertices; i++) {
            const offset = i * vertexSize;
            vertices.push({
                position: [
                    dataView.getFloat32(offset, true),
                    dataView.getFloat32(offset + 4, true),
                    dataView.getFloat32(offset + 8, true)
                ],
                texCoord: [
                    dataView.getFloat32(offset + 12, true),
                    dataView.getFloat32(offset + 16, true)
                ],
                normal: [
                    dataView.getFloat32(offset + 28, true),
                    dataView.getFloat32(offset + 32, true),
                    dataView.getFloat32(offset + 36, true)
                ],
                color: [
                    dataView.getUint8(offset + 40),
                    dataView.getUint8(offset + 41),
                    dataView.getUint8(offset + 42),
                    dataView.getUint8(offset + 43)
                ]
            });
        }

        return vertices;
    }

    parseFaces(arrayBuffer, lump) {
        const faces = [];
        const dataView = new DataView(arrayBuffer, lump.offset, lump.length);
        const faceSize = 104;
        const numFaces = lump.length / faceSize;

        for (let i = 0; i < numFaces; i++) {
            const offset = i * faceSize;
            faces.push({
                texture: dataView.getInt32(offset, true),
                type: dataView.getInt32(offset + 8, true),
                vertex: dataView.getInt32(offset + 12, true),
                numVerts: dataView.getInt32(offset + 16, true),
                meshVert: dataView.getInt32(offset + 20, true),
                numMeshVerts: dataView.getInt32(offset + 24, true)
            });
        }

        return faces;
    }

    parseMeshVerts(arrayBuffer, lump) {
        const meshVerts = [];
        const dataView = new DataView(arrayBuffer, lump.offset, lump.length);
        const numMeshVerts = lump.length / 4;

        for (let i = 0; i < numMeshVerts; i++) {
            meshVerts.push(dataView.getInt32(i * 4, true));
        }

        return meshVerts;
    }

    // Create Three.js geometry with materials
    createThreeJSGeometry(mapData) {
        const geometry = new THREE.BufferGeometry();
        const positions = [];
        const normals = [];
        const uvs = [];
        const colors = [];

        // Process polygon and mesh faces
        for (const face of mapData.bsp.faces) {
            if (face.type === 1 || face.type === 3) {
                for (let i = 0; i < face.numMeshVerts; i += 3) {
                    for (let j = 0; j < 3; j++) {
                        const meshVertIndex = face.meshVert + i + j;
                        if (meshVertIndex < mapData.bsp.meshVerts.length) {
                            const vertIndex = face.vertex + mapData.bsp.meshVerts[meshVertIndex];
                            const vertex = mapData.bsp.vertices[vertIndex];

                            positions.push(...vertex.position);
                            normals.push(...vertex.normal);
                            uvs.push(...vertex.texCoord);
                            colors.push(...vertex.color);
                        }
                    }
                }
            }
        }

        // Construct buffers
        geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
        geometry.setAttribute('normal', new THREE.Float32BufferAttribute(normals, 3));
        geometry.setAttribute('uv', new THREE.Float32BufferAttribute(uvs, 2));
        geometry.setAttribute('color', new THREE.Uint8BufferAttribute(colors, 4));

        // Compute vertex tangents
        geometry.computeTangents();

        return geometry;
    }

    // Create materials for the loaded map
    createMaterials(mapData) {
        const materials = new Map();

        // Create basic material for each texture
        for (const texture of mapData.textures) {
            if (texture.name) {
                const material = new THREE.MeshStandardMaterial({
                    map: texture,
                    side: THREE.DoubleSide
                });
                materials.set(texture.name.toLowerCase(), material);
            }
        }

        return materials;
    }

    // Add map objects to the scene
    async addMapObjectsToScene(mapData, options = {}) {
        this.clearMapObjects();

        // Extract options
        const { withPlayer = true, withPath = false } = options;

        // Create materials
        const materials = this.createMaterials(mapData);

        // Create meshes for brushes and entities
        for (const [i, brush] of mapData.bsp.faces.entries()) {
            if (brush.type === 1 || brush.type === 3) {
                const geometry = new THREE.BufferGeometry();
                const positions = [];
                const normals = [];
                const uvs = [];

                for (let j = 0; j < brush.numMeshVerts; j += 3) {
                    for (let k = 0; k < 3; k++) {
                        const meshVertIndex = brush.meshVert + j + k;
                        if (meshVertIndex < mapData.bsp.meshVerts.length) {
                            const vertIndex = brush.vertex + mapData.bsp.meshVerts[meshVertIndex];
                            const vertex = mapData.bsp.vertices[vertIndex];

                            positions.push(...vertex.position);
                            normals.push(...vertex.normal);
                            uvs.push(...vertex.texCoord);
                        }
                    }
                }

                // Construct buffers
                geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
                geometry.setAttribute('normal', new THREE.Float32BufferAttribute(normals, 3));
                geometry.setAttribute('uv', new THREE.Float32BufferAttribute(uvs, 2));

                // Compute vertex tangents
                geometry.computeTangents();

                // Create material
                const textureName = mapData.textures.get(brush.texture)?.name.toLowerCase();
                let material = textureName ? materials.get(textureName) : null;

                if (!material) {
                    // Fallback to a simple material
                    material = new THREE.MeshStandardMaterial({
                        color: new THREE.Color(Math.random(), Math.random(), Math.random()),
                        side: THREE.DoubleSide
                    });
                }

                // Create mesh
                const mesh = new THREE.Mesh(geometry, material);
                this.scene.add(mesh);
            }
        }

        // TODO: Handle entities like spawn points, triggers, etc.

        // If enabled, add player and path visualizations
        if (withPlayer) {
            this.addPlayerVisualization(mapData);
        }

        if (withPath) {
            this.addPathVisualization(mapData);
        }
    }

    // Add player visualization
    addPlayerVisualization(mapData) {
        const playerMaterial = new THREE.MeshStandardMaterial({ color: 0xff0000 });
        const playerGeometry = new THREE.SphereBufferGeometry(10, 16, 16);

        for (const entity of mapData.entities) {
            if (entity.properties.classname?.includes('player')) {
                const [x, y, z] = this.parseOrigin(entity.properties.origin);
                const playerMesh = new THREE.Mesh(playerGeometry, playerMaterial);
                playerMesh.position.set(x, y, z);
                playerMesh.castShadow = true;
                playerMesh.receiveShadow = true;
                this.scene.add(playerMesh);
            }
        }
    }

    // Add path visualization
    addPathVisualization(mapData) {
        const pathMaterial = new THREE.LineBasicMaterial({ color: 0x00ff00 });
        const points = [];

        for (const entity of mapData.entities) {
            if (entity.properties.classname?.includes('path')) {
                const [x, y, z] = this.parseOrigin(entity.properties.origin);
                points.push(new THREE.Vector3(x, y, z));
            }
        }

        if (points.length > 1) {
            const pathGeometry = new THREE.BufferGeometry().setFromPoints(points);
            const pathLine = new THREE.Line(pathGeometry, pathMaterial);
            this.scene.add(pathLine);
        }
    }

    // Clear existing map objects from the scene
    clearMapObjects() {
        // TODO: Implement clearing of map objects, player, path, etc.
    }
}

